<Window x:Class="DoubleMark.Desktop.PrintSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ui="clr-namespace:DoubleMark.Desktop"
        Title="Настройки печати"
        Height="640"
        Width="760"
        MinHeight="560"
        MinWidth="700"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource DialogWindowFrame}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource DialogTitleBar}"
                    ui:DialogWindowChrome.IsDragArea="True">
                <Grid>
                    <TextBlock Text="Настройки печати" Style="{StaticResource DialogTitleText}"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource TitleBarButton}"
                                Content="—"
                                ui:DialogWindowChrome.WindowCommand="Minimize"/>
                        <Button Style="{StaticResource TitleBarButton}"
                                Content="□"
                                ui:DialogWindowChrome.WindowCommand="MaximizeRestore"/>
                        <Button Style="{StaticResource TitleBarCloseButton}"
                                Content="×"
                                ui:DialogWindowChrome.WindowCommand="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource HeroCard}" Margin="0,0,0,16">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Настройки печати" Style="{StaticResource CardTitle}" FontSize="21"/>
                            <TextBlock Text="Автопечать, принтер, шаблон и локальное сохранение этикеток."
                                       Style="{StaticResource MutedText}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                        <Border Style="{StaticResource PillBadge}" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <TextBlock Text="Локально" Foreground="{StaticResource SuccessBrush}" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Поведение после сканирования" Style="{StaticResource CardTitle}" Margin="0,0,0,14"/>
                                <UniformGrid Columns="3">
                                    <CheckBox x:Name="AutoPrintCheck"
                                              Content="Автопечать после сканирования"
                                              Margin="0,0,16,8"/>
                                    <CheckBox x:Name="SilentPrintCheck"
                                              Content="Печатать без подтверждения"
                                              Margin="0,0,16,8"/>
                                    <CheckBox x:Name="SaveBeforePrintCheck"
                                              Content="Сохранять файл перед печатью"
                                              Margin="0,0,0,8"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Принтер" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                <ComboBox x:Name="PrinterCombo"
                                          Grid.Row="0"
                                          Grid.Column="1"
                                          Style="{StaticResource DashboardComboBox}"
                                          Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Шаблон" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                <ComboBox x:Name="TemplateCombo"
                                          Grid.Row="1"
                                          Grid.Column="1"
                                          Style="{StaticResource DashboardComboBox}"
                                          SelectionChanged="OnTemplateSelectionChanged"
                                          Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Количество копий" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                <TextBox x:Name="CopiesText"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Задержка, мс" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                <TextBox x:Name="DelayText"
                                         Grid.Row="3"
                                         Grid.Column="1"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Защита от дублей, сек." Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                <TextBox x:Name="DuplicateText"
                                         Grid.Row="4"
                                         Grid.Column="1"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Папка сохранения" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                <Grid Grid.Row="5" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PrintFolderText" Grid.Column="0" Margin="0,0,10,0"/>
                                    <Button Grid.Column="1"
                                            Content="Выбрать"
                                            Click="OnBrowseClick"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,8,0"/>
                                    <Button Grid.Column="2"
                                            Content="Открыть"
                                            Click="OnOpenFolderClick"
                                            Style="{StaticResource SecondaryButton}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SoftSurface}">
                            <StackPanel>
                                <TextBlock Text="Статус" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="StatusText"
                                           Foreground="{StaticResource AccentBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="19"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <DockPanel Grid.Row="2" Margin="0,16,0,0" LastChildFill="False">
                    <Button Content="Тестовая печать шаблона"
                            Click="OnTestPrintClick"
                            Style="{StaticResource TealButton}"
                            DockPanel.Dock="Left"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="Сохранить"
                                Click="OnSaveClick"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="120"
                                Margin="0,0,8,0"/>
                        <Button Content="Отмена"
                                Click="OnCancelClick"
                                Style="{StaticResource SecondaryButton}"
                                MinWidth="110"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
