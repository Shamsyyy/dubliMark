<UserControl x:Class="DoubleMark.Desktop.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DoubleMark.Desktop.Views"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,0,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource HeroCard}" Margin="0,0,16,0">
                <StackPanel>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Шаблоны печати" Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="TemplatesSyncStatusText" Text="Шаблоны синхронизированы"
                                       Style="{StaticResource MutedText}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Редактор шаблонов"
                                Click="OnManageClick" Padding="12,9" VerticalAlignment="Top"/>
                    </Grid>

                    <ScrollViewer x:Name="TemplatesListScroll"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,8">
                        <StackPanel x:Name="TemplatesListPanel"/>
                    </ScrollViewer>

                    <WrapPanel Margin="0,0,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Content="Создать" Click="OnCreateClick"
                                Margin="0,0,8,8" MinWidth="96"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Копировать" Click="OnCopyClick"
                                Margin="0,0,8,8" MinWidth="96"/>
                        <Button Style="{StaticResource DangerButton}" Content="Удалить" Click="OnDeleteClick"
                                Margin="0,0,0,8" MinWidth="96"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="0" Grid.Column="1">
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Размер DataMatrix" Style="{StaticResource CardTitle}" Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,16">
                            <Button Style="{StaticResource SecondaryButton}" Tag="8:8" Click="OnPresetClick" Padding="10,6" Margin="0,0,6,6">8×8</Button>
                            <Button Style="{StaticResource SecondaryButton}" Tag="10:10" Click="OnPresetClick" Padding="10,6" Margin="0,0,6,6">10×10</Button>
                            <Button Style="{StaticResource SecondaryButton}" Tag="13:13" Click="OnPresetClick" Padding="10,6" Margin="0,0,6,6">13×13</Button>
                            <Button Style="{StaticResource SecondaryButton}" Tag="15:15" Click="OnPresetClick" Padding="10,6" Margin="0,0,6,6">15×15</Button>
                            <Button Style="{StaticResource SecondaryButton}" Tag="20:30" Click="OnPresetClick" Padding="10,6" Margin="0,0,6,6">20×30</Button>
                            <Button Style="{StaticResource SecondaryButton}" Tag="25:25" Click="OnPresetClick" Padding="10,6" Margin="0,0,0,6">25×25</Button>
                        </WrapPanel>

                        <TextBlock Text="Этикетка и DataMatrix (0.1 – 50 мм)" Style="{StaticResource MutedText}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="58"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ширина этик." Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="6" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="6,4">
                                <TextBox x:Name="LabelWidthBox" Text="30.0" Background="Transparent" BorderThickness="0" Padding="0"
                                         FontSize="13" VerticalAlignment="Center" TextChanged="OnDimensionBoxChanged"/>
                            </Border>
                            <Slider Grid.Column="3" x:Name="LabelWidthSlider" Minimum="0.1" Maximum="50" Value="30"
                                    SmallChange="0.1" LargeChange="1"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="58"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Высота этик." Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="6" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="6,4">
                                <TextBox x:Name="LabelHeightBox" Text="20.0" Background="Transparent" BorderThickness="0" Padding="0"
                                         FontSize="13" VerticalAlignment="Center" TextChanged="OnDimensionBoxChanged"/>
                            </Border>
                            <Slider Grid.Column="3" x:Name="LabelHeightSlider" Minimum="0.1" Maximum="50" Value="20"
                                    SmallChange="0.1" LargeChange="1"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="58"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DM ширина" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="6" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="6,4">
                                <TextBox x:Name="DmWidthBox" Text="14.0" Background="Transparent" BorderThickness="0" Padding="0"
                                         FontSize="13" VerticalAlignment="Center" TextChanged="OnDimensionBoxChanged"/>
                            </Border>
                            <Slider Grid.Column="3" x:Name="DmWidthSlider" Minimum="0.1" Maximum="50" Value="14"
                                    SmallChange="0.1" LargeChange="1"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="58"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DM высота" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="6" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="6,4">
                                <TextBox x:Name="DmHeightBox" Text="14.0" Background="Transparent" BorderThickness="0" Padding="0"
                                         FontSize="13" VerticalAlignment="Center" TextChanged="OnDimensionBoxChanged"/>
                            </Border>
                            <Slider Grid.Column="3" x:Name="DmHeightSlider" Minimum="0.1" Maximum="50" Value="14"
                                    SmallChange="0.1" LargeChange="1"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="58"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DM X" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="6" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="6,4">
                                <TextBox x:Name="DmXBox" Text="2.0" Background="Transparent" BorderThickness="0" Padding="0"
                                         FontSize="13" VerticalAlignment="Center" TextChanged="OnDimensionBoxChanged"/>
                            </Border>
                            <Slider Grid.Column="3" x:Name="DmXSlider" Minimum="0" Maximum="50" Value="2"
                                    SmallChange="0.1" LargeChange="1"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="58"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DM Y" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="6" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="6,4">
                                <TextBox x:Name="DmYBox" Text="3.0" Background="Transparent" BorderThickness="0" Padding="0"
                                         FontSize="13" VerticalAlignment="Center" TextChanged="OnDimensionBoxChanged"/>
                            </Border>
                            <Slider Grid.Column="3" x:Name="DmYSlider" Minimum="0" Maximum="50" Value="3"
                                    SmallChange="0.1" LargeChange="1"/>
                        </Grid>

                        <Button Style="{StaticResource TealButton}" Content="Применить размеры" Click="OnApplyLayoutClick" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Текст на этикетке" Style="{StaticResource CardTitle}" Margin="0,0,0,10"/>
                        <TextBlock Text="Плейсхолдеры: {date}, {time}, {shipment}, {order}, {gtin}, {serial}"
                                   Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <TextBlock Text="Строки шаблона — X/Y в мм от левого верхнего угла этикетки"
                                   Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Шрифт" VerticalAlignment="Center"
                                       Style="{StaticResource CardTitle}" FontSize="13"/>
                            <ComboBox x:Name="LabelFontCombo" Grid.Column="2" MinWidth="220"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="OnLabelFontSelectionChanged"/>
                        </Grid>
                        <TextBlock Text="Arial и Verdana — максимальная читаемость при дефектах печати; Segoe UI, Calibri и Georgia — декоративные."
                                   Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <StackPanel x:Name="TextBlocksEditorPanel" Margin="0,0,0,10"/>

                        <Button Style="{StaticResource SecondaryButton}" Content="Создать новый текст"
                                Click="OnAddTextBlockClick" HorizontalAlignment="Left" Margin="0,0,0,10"/>

                        <TextBlock Text="Подстановки из QR — нажмите, чтобы вставить в выбранную строку:"
                                   Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <WrapPanel x:Name="PlaceholderButtonsPanel"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource Card}" Margin="0,14,0,0">
                <StackPanel>
                    <TextBlock Text="Макет этикетки" Style="{StaticResource CardTitle}" Margin="0,0,0,10"/>
                    <Grid Grid.IsSharedSizeScope="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="LayoutMeta"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="LayoutToolbar"/>
                            <RowDefinition Height="340"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="LayoutHint"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Предпросмотр печати"
                                   Style="{StaticResource CardTitle}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Редактор макета"
                                   Style="{StaticResource CardTitle}" Margin="0,0,0,8"/>

                        <Grid Grid.Row="1" Grid.RowSpan="4" Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" SharedSizeGroup="LayoutMeta"/>
                                <RowDefinition Height="Auto" SharedSizeGroup="LayoutToolbar"/>
                                <RowDefinition Height="340"/>
                                <RowDefinition Height="Auto" SharedSizeGroup="LayoutHint"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="2" Background="#F7FAFC" CornerRadius="18"
                                    Padding="18" ClipToBounds="True"
                                    Height="340" MinHeight="340" MaxHeight="340">
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TemplatePreviewPlaceholder"
                                               Text="Предпросмотр появится после выбора шаблона"
                                               Style="{StaticResource MutedText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                    <Image x:Name="TemplatePreviewImage" Stretch="Uniform" MaxHeight="300" MaxWidth="300"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <views:TemplateLayoutCanvas Grid.Row="1" Grid.RowSpan="4" Grid.Column="2" x:Name="LayoutCanvas"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
