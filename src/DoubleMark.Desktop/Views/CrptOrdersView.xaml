<UserControl x:Class="DoubleMark.Desktop.Views.CrptOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <Grid Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCard}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Заказы кодов СУЗ" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Создание заказа по GTIN из локального каталога и скачивание кодов."
                           Style="{StaticResource MutedText}" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel>
                <Border Style="{StaticResource SoftSurface}" Margin="0,0,0,12">
                    <TextBlock Text="Обновите каталог из Национального каталога, чтобы заказать коды."
                               Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCatalogEmpty}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <TextBlock Text="Новый заказ" Style="{StaticResource CardTitle}"/>
                <Grid Margin="0,14,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="GTIN" Style="{StaticResource MetricLabel}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding OrderableItems}"
                              DisplayMemberPath="Gtin" SelectedValuePath="Gtin"
                              SelectedValue="{Binding SelectedGtin}" Margin="0,0,12,8"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Количество" Style="{StaticResource MetricLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Text="Товарная группа" Style="{StaticResource MetricLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProductGroupDisplay}" IsReadOnly="True" Margin="0,0,12,8"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="templateId" Style="{StaticResource MetricLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding TemplateId}" IsReadOnly="True"/>
                </Grid>
                <Button Style="{StaticResource PrimaryButton}" Content="Создать заказ и скачать коды"
                        Command="{Binding CreateOrderCommand}" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding ProgressText}" Style="{StaticResource MutedText}" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Заказы" Style="{StaticResource CardTitle}" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Скачать коды"
                            Command="{Binding DownloadCodesCommand}" Margin="16,0,8,0"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Открыть очередь печати"
                            Command="{Binding OpenPrintQueueCommand}"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                           Margin="0,10,0,0" TextWrapping="Wrap"/>
                <DataGrid ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrder}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat=g}" Width="140"/>
                        <DataGridTextColumn Header="GTIN" Binding="{Binding Gtin}" Width="130"/>
                        <DataGridTextColumn Header="Qty" Binding="{Binding RequestedQuantity}" Width="60"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding RemoteStatus}" Width="120"/>
                        <DataGridTextColumn Header="Ошибка" Binding="{Binding ErrorMessage}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
