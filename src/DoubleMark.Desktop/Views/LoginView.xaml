<UserControl x:Class="DoubleMark.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <Grid Margin="24,0,24,24">
        <Border Style="{StaticResource HeroCard}" MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Вход в DoubleMark" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Используйте тот же аккаунт, что на сайте DoubleMark."
                           Style="{StaticResource MutedText}" Margin="0,6,0,22" TextWrapping="Wrap"/>

                <TextBlock Text="Email" Style="{StaticResource MetricLabel}" Margin="0,0,0,6"/>
                <TextBox x:Name="EmailText" Style="{StaticResource InputBox}" Margin="0,0,0,14"/>

                <TextBlock Text="Пароль" Style="{StaticResource MetricLabel}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordText" Style="{StaticResource InputPasswordBox}" Margin="0,0,0,16"/>

                <Button x:Name="SignInButton" Style="{StaticResource PrimaryButton}" Content="Войти" Click="OnSignInClick"/>

                <UniformGrid Columns="2" Margin="0,12,0,0">
                    <Button Style="{StaticResource SecondaryButton}" Content="Забыли пароль?" Click="OnResetPasswordClick" Margin="0,0,6,0"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Создать аккаунт" Click="OnRegisterClick" Margin="6,0,0,0"/>
                </UniformGrid>

                <TextBlock x:Name="StatusText" Style="{StaticResource MutedText}" Foreground="{StaticResource WarningBrush}"
                           TextWrapping="Wrap" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
