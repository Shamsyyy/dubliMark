<UserControl x:Class="DoubleMark.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <Border Style="{StaticResource HeroCard}">
        <StackPanel>
            <TextBlock Text="Dashboard" Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="Основная рабочая панель DoubleMark встроена в shell, чтобы сохранить существующие x:Name и обработчики."
                       Style="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>
