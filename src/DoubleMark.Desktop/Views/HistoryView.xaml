<UserControl x:Class="DoubleMark.Desktop.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,8">
        <Grid Margin="24,0,24,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource HeroCard}" Margin="0,0,0,16">
                <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="История сканирования" Style="{StaticResource SectionTitle}"/>
                        <TextBlock x:Name="HistoryUsageText" Text="История: 0 / 1000" Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                        <TextBlock x:Name="HistoryLimitWarningText" Text="" Style="{StaticResource MutedText}" Margin="0,4,0,0"
                                   Foreground="{StaticResource WarningBrush}" Visibility="Collapsed"/>
                        <TextBlock x:Name="HistorySignedOutText" Text="Облачная история доступна после входа. Локальный режим работает без аккаунта."
                                   Style="{StaticResource MutedText}" Margin="0,6,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                    <TextBox x:Name="HistorySearchBox" Grid.Column="1" Style="{StaticResource InputBox}"
                             TextChanged="OnFilterChanged"/>
                    <ComboBox x:Name="HistoryStatusFilter" Grid.Column="3" Style="{StaticResource DashboardComboBox}"
                              SelectionChanged="OnFilterChanged"/>
                    <Button Grid.Column="5" Style="{StaticResource SecondaryButton}" Content="Очистить историю"
                            Click="OnClearHistoryClick" VerticalAlignment="Center"/>
                </Grid>
                <Border Margin="0,14,0,0" Padding="12" Style="{StaticResource SoftSurface}">
                    <StackPanel>
                        <TextBlock Text="Хранение и режим просмотра" Style="{StaticResource MetricLabel}" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <CheckBox x:Name="CloudStorageCheck" Content="Supabase (облако)" Margin="0,0,16,6"
                                      Checked="OnSettingsControlChanged" Unchecked="OnSettingsControlChanged"/>
                            <CheckBox x:Name="LocalStorageCheck" Content="Локально на ПК" Margin="0,0,16,6"
                                      Checked="OnSettingsControlChanged" Unchecked="OnSettingsControlChanged"/>
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <RadioButton x:Name="ViewCloudRadio" GroupName="HistoryViewMode" Content="Показ: облако"
                                         Margin="0,0,14,0" Checked="OnSettingsControlChanged"/>
                            <RadioButton x:Name="ViewLocalRadio" GroupName="HistoryViewMode" Content="Показ: локально"
                                         Margin="0,0,14,0" Checked="OnSettingsControlChanged"/>
                            <Button Style="{StaticResource SecondaryButton}" Content="Выбрать папку…"
                                    Click="OnBrowseFolderClick" Margin="0,0,8,0"/>
                            <Button Style="{StaticResource SecondaryButton}" Content="Обновить"
                                    Click="OnReloadClick"/>
                        </StackPanel>
                        <TextBlock x:Name="LocalFolderText" Style="{StaticResource MutedText}" Margin="0,8,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SelectionHintText" Text="Выделите нужные ЧЗ кнопкой «Выделить», затем сохраните в отдельную папку."
                                   Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                        <Button x:Name="ExportSelectedButton" Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                Content="Сохранить выделенные в папку…" IsEnabled="False"
                                Click="OnExportSelectedClick" Margin="12,0,0,0"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="148"/>
                            <ColumnDefinition Width="88"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="Auto" MinWidth="56"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="420" MinWidth="380"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Время" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Grid.Column="1" Text="Источник" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Grid.Column="2" Text="GTIN / SN" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Grid.Column="3" Text="ЧЗ" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Grid.Column="4" Text="AI / Preview" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Grid.Column="5" Text="Действия" Style="{StaticResource MetricLabel}"/>
                    </Grid>
                    <StackPanel x:Name="HistoryRowsPanel"/>
                    <TextBlock x:Name="HistoryEmptyText" Text="История пока пустая. Отсканируйте код ЧЗ."
                               Style="{StaticResource MutedText}" Visibility="Collapsed" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
