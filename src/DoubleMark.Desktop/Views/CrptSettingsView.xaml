<UserControl x:Class="DoubleMark.Desktop.Views.CrptSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,0,24,24">
            <Border Style="{StaticResource HeroCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Настройки маркировки CRPT" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Роли, СУЗ, сертификат, доступ True API и Национальный каталог."
                               Style="{StaticResource MutedText}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Контур CRPT" Style="{StaticResource CardTitle}"/>
                    <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,10,0,12"
                               Text="{Binding EnvironmentWhenToUseHint}"/>
                    <ComboBox Margin="0,0,0,10"
                              ItemsSource="{Binding EnvironmentOptions}"
                              SelectedItem="{Binding SelectedEnvironmentOption}"
                              DisplayMemberPath="DisplayName"/>
                    <TextBlock Text="{Binding SelectedEnvironmentDescription}"
                               Style="{StaticResource MetricValue}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Border Padding="12,10" CornerRadius="8"
                            Background="{StaticResource WarningBadgeBackgroundBrush}"
                            BorderBrush="{StaticResource WarningBrush}" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowProductionConnectivityWarning}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ProductionConnectivityWarning}"
                                   Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Роль и товарные группы" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="Роль организации" Style="{StaticResource MetricLabel}" Margin="0,14,0,6"/>
                    <ItemsControl ItemsSource="{Binding RoleSelections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}"
                                          IsEnabled="{Binding IsEnabled}" Margin="0,0,0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="Товарные группы" Style="{StaticResource MetricLabel}" Margin="0,12,0,6"/>
                    <ItemsControl ItemsSource="{Binding ProductGroupSelections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Margin="0,0,0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="GS1 и СУЗ" Style="{StaticResource CardTitle}"/>
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="ИНН" Style="{StaticResource MetricLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Inn, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Text="GS1 рег. №" Style="{StaticResource MetricLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Gs1OrganizationNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="2" Text="SUZ URL" Style="{StaticResource MetricLabel}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SuzBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="3" Text="OMS ID" Style="{StaticResource MetricLabel}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding OmsId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="4" Text="Connection ID" Style="{StaticResource MetricLabel}"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ConnectionId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="5" Text="Контакт" Style="{StaticResource MetricLabel}"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Сертификат УКЭП" Style="{StaticResource CardTitle}"/>
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Сертификат" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Certificates}"
                                  SelectedItem="{Binding SelectedCertificate}"
                                  DisplayMemberPath="Subject" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Обновить"
                                Command="{Binding ReloadCertificatesCommand}"/>
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Thumbprint" Style="{StaticResource MetricLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding CertificateThumbprint, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Срок УКЭП" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding CertificateExpiryText}" Style="{StaticResource MetricValue}"/>
                    </Grid>
                    <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,10,0,0"
                               Text="Подпись УКЭП через CryptoPro CAdESCOM поддерживается только в Windows."/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Доступ True API" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding TokenExpiresText}" Style="{StaticResource MetricValue}" Margin="0,14,0,10"/>
                    <CheckBox Content="Автопродление токена" IsChecked="{Binding AutoRefreshToken}" Margin="0,0,0,12"/>
                    <UniformGrid Columns="3">
                        <Button Style="{StaticResource SecondaryButton}" Content="Проверить подключение"
                                Command="{Binding TestConnectionCommand}" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Продлить"
                                Command="{Binding RefreshTokenCommand}" Margin="3,0,3,0"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="Сохранить"
                                Command="{Binding SaveCommand}" Margin="6,0,0,0"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Национальный каталог" Style="{StaticResource CardTitle}"/>
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="URL НК" Style="{StaticResource MetricLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NkBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="True API URL" Style="{StaticResource MetricLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TrueApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    </Grid>
                    <CheckBox Content="Использовать JWT True API для НК" IsChecked="{Binding NkUseJwtFromTrueApi}" Margin="0,8,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="API KEY НК" Style="{StaticResource MetricLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding NkApiKey, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <TextBlock Text="Категории каталога НК" Style="{StaticResource MetricLabel}" Margin="0,8,0,6"/>
                    <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Выберите категории, которые будут видны в каталоге. Пустой выбор — показать все. Список пополняется при синхронизации."/>
                    <UniformGrid Columns="2" Margin="0,0,0,8">
                        <Button Style="{StaticResource SecondaryButton}" Content="Показать все"
                                Command="{Binding ShowAllCategoriesCommand}" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Снять все"
                                Command="{Binding ClearAllCategoriesCommand}" Margin="6,0,0,0"/>
                    </UniformGrid>
                    <ItemsControl ItemsSource="{Binding CategorySelections}" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding CategoryName}" IsChecked="{Binding IsSelected}" Margin="0,0,0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <CheckBox Content="Только опубликованные карточки" IsChecked="{Binding NkSyncOnlyPublished}"
                              IsEnabled="False" Margin="0,0,0,4">
                        <CheckBox.ToolTip>
                            <ToolTip Content="Фильтруйте в каталоге"/>
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <CheckBox Content="Только подписанные карточки" IsChecked="{Binding NkSyncOnlySigned}"
                              IsEnabled="False" Margin="0,0,0,12">
                        <CheckBox.ToolTip>
                            <ToolTip Content="Фильтруйте в каталоге"/>
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <TextBlock Text="templateId по товарной группе" Style="{StaticResource MetricLabel}" Margin="0,0,0,6"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Обновить шаблоны по группам"
                            Click="OnSyncProductGroupsClick" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding TemplateDefaults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ProductGroupDisplay}" Style="{StaticResource MetricValue}"/>
                                    <TextBox Grid.Column="1" Text="{Binding TemplateId, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Документация" Style="{StaticResource CardTitle}"/>
                    <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,14,0,8"
                               Text="API СУЗ 3.0: скачать из ЛК Честного ЗНАКа → Помощь (промышленный контур)."/>
                    <UniformGrid Columns="3" Margin="0,0,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Content="True API"
                                Click="OnTrueApiDocsClick" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Национальный каталог"
                                Click="OnNationalCatalogDocsClick" Margin="3,0,3,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="База знаний"
                                Click="OnKnowledgeBaseClick" Margin="6,0,0,0"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="Интеграция с ЦРПТ выполняется от имени участника оборота (УОТ). Юридическая ответственность за заказ кодов маркировки, отчётность и ввод в оборот несёт УОТ. Для коммерческой передачи интеграции другим УОТ требуется регистрация технологическим партнёром ЦРПТ."/>

            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
