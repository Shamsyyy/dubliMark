<UserControl x:Class="DoubleMark.Desktop.Views.TemplateLayoutCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <StackPanel>
        <Grid Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Name="ScaleInfoText" Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
            <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,8,0,0">
                <TextBlock Text="Блок:" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <Button x:Name="LayoutToggleButton" Content="Гориз." Style="{StaticResource SecondaryButton}"
                        Padding="10,4" Margin="0,0,12,4" ToolTip="Ориентация блока: горизонталь / вертикаль" Click="OnLayoutToggleClick" IsEnabled="False"/>
                <TextBlock Text="Текст:" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <Button x:Name="DirRightButton" Content="→" Style="{StaticResource SecondaryButton}"
                        Padding="8,4" Margin="0,0,4,4" ToolTip="Текст вправо" Click="OnDirRightClick" IsEnabled="False"/>
                <Button x:Name="DirLeftButton" Content="←" Style="{StaticResource SecondaryButton}"
                        Padding="8,4" Margin="0,0,4,4" ToolTip="Текст влево" Click="OnDirLeftClick" IsEnabled="False"/>
                <Button x:Name="DirDownButton" Content="↓" Style="{StaticResource SecondaryButton}"
                        Padding="8,4" Margin="0,0,4,4" ToolTip="Начало сверху, конец снизу" Click="OnDirDownClick" IsEnabled="False"/>
                <Button x:Name="DirUpButton" Content="↑" Style="{StaticResource SecondaryButton}"
                        Padding="8,4" Margin="0,0,12,4" ToolTip="Начало снизу, конец сверху" Click="OnDirUpClick" IsEnabled="False"/>
                <TextBlock Text="Размер pt:" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <Button x:Name="FontSmallerButton" Content="−" Style="{StaticResource SecondaryButton}" Padding="10,4" Margin="0,0,0,4" Click="OnFontSmallerClick"/>
                <TextBox x:Name="SelectedFontSizeBox" Width="44" Margin="6,0,6,4" Padding="4,2"
                         Text="—" TextAlignment="Center" VerticalContentAlignment="Center"
                         LostFocus="OnFontSizeBoxLostFocus" KeyDown="OnFontSizeBoxKeyDown" IsEnabled="False"/>
                <Button x:Name="FontLargerButton" Content="+" Style="{StaticResource SecondaryButton}" Padding="10,4" Margin="0,0,0,4" Click="OnFontLargerClick"/>
            </WrapPanel>
        </Grid>
        <Border Background="#EEF2F6" CornerRadius="12" Padding="12" ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="340">
                <Canvas x:Name="LayoutCanvas" Background="#F7FAFC"/>
            </ScrollViewer>
        </Border>
        <TextBlock Text="Блок Г/В — направление текста → ← ↓ ↑. Позиция сохраняется, текст может заходить на DM."
                   Style="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
