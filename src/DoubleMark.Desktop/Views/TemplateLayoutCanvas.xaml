<UserControl x:Class="DoubleMark.Desktop.Views.TemplateLayoutCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <StackPanel>
        <Grid Margin="0,0,0,8">
            <TextBlock x:Name="ScaleInfoText" Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Ориентация:" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button x:Name="LayoutToggleButton" Content="Гориз." Style="{StaticResource SecondaryButton}"
                        Padding="10,4" Margin="0,0,12,0" ToolTip="Горизонтальная / вертикальная" Click="OnLayoutToggleClick" IsEnabled="False"/>
                <TextBlock Text="Направление:" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button x:Name="DirRightButton" Content="→" Style="{StaticResource SecondaryButton}"
                        Padding="8,4" Margin="0,0,4,0" ToolTip="Слева направо" Click="OnDirRightClick" IsEnabled="False"/>
                <Button x:Name="DirLeftButton" Content="←" Style="{StaticResource SecondaryButton}"
                        Padding="8,4" Margin="0,0,4,0" ToolTip="Справа налево" Click="OnDirLeftClick" IsEnabled="False"/>
                <Button x:Name="DirDownButton" Content="↓" Style="{StaticResource SecondaryButton}"
                        Padding="8,4" Margin="0,0,4,0" ToolTip="Сверху вниз, лицом влево" Click="OnDirDownClick" IsEnabled="False"/>
                <Button x:Name="DirUpButton" Content="↑" Style="{StaticResource SecondaryButton}"
                        Padding="8,4" Margin="0,0,12,0" ToolTip="Снизу вверх, лицом вправо" Click="OnDirUpClick" IsEnabled="False"/>
                <TextBlock Text="Размер pt:" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button x:Name="FontSmallerButton" Content="−" Style="{StaticResource SecondaryButton}" Padding="10,4" Click="OnFontSmallerClick"/>
                <TextBox x:Name="SelectedFontSizeBox" Width="44" Margin="6,0" Padding="4,2"
                         Text="—" TextAlignment="Center" VerticalContentAlignment="Center"
                         LostFocus="OnFontSizeBoxLostFocus" KeyDown="OnFontSizeBoxKeyDown" IsEnabled="False"/>
                <Button x:Name="FontLargerButton" Content="+" Style="{StaticResource SecondaryButton}" Padding="10,4" Click="OnFontLargerClick"/>
            </StackPanel>
        </Grid>
        <Border Background="#EEF2F6" CornerRadius="12" Padding="12" ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="340">
                <Canvas x:Name="LayoutCanvas" Background="#F7FAFC"/>
            </ScrollViewer>
        </Border>
        <TextBlock Text="Перетащите строку на макет. Ориентация Г/В, направление → ← или ↓ ↑."
                   Style="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
