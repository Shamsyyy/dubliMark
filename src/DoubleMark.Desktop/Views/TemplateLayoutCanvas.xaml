<UserControl x:Class="DoubleMark.Desktop.Views.TemplateLayoutCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" SharedSizeGroup="LayoutMeta"/>
            <RowDefinition Height="Auto" SharedSizeGroup="LayoutToolbar"/>
            <RowDefinition Height="340"/>
            <RowDefinition Height="Auto" SharedSizeGroup="LayoutHint"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="ScaleInfoText"
                   Style="{StaticResource MutedText}"
                   TextWrapping="Wrap" Margin="0,0,0,6"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Блок" Style="{StaticResource CardTitle}" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button x:Name="LayoutToggleButton" Content="Гориз." Style="{StaticResource EditorToolbarButton}"
                        MinWidth="52" Margin="0,0,16,0"
                        ToolTip="Ориентация блока: горизонталь / вертикаль" Click="OnLayoutToggleClick" IsEnabled="False"/>

                <TextBlock Text="Направление" Style="{StaticResource CardTitle}" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button x:Name="DirRightButton" Content="→" Style="{StaticResource EditorToolbarButton}"
                        Margin="0,0,4,0" ToolTip="Текст вправо" Click="OnDirRightClick" IsEnabled="False"/>
                <Button x:Name="DirLeftButton" Content="←" Style="{StaticResource EditorToolbarButton}"
                        Margin="0,0,4,0" ToolTip="Текст влево" Click="OnDirLeftClick" IsEnabled="False"/>
                <Button x:Name="DirDownButton" Content="↓" Style="{StaticResource EditorToolbarButton}"
                        Margin="0,0,4,0" ToolTip="Сверху вниз" Click="OnDirDownClick" IsEnabled="False"/>
                <Button x:Name="DirUpButton" Content="↑" Style="{StaticResource EditorToolbarButton}"
                        ToolTip="Снизу вверх" Click="OnDirUpClick" IsEnabled="False"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Шрифт" Style="{StaticResource CardTitle}" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="CanvasFontCombo" Grid.Column="1" Style="{StaticResource EditorToolbarCombo}"
                          DisplayMemberPath="DisplayName" Margin="0,0,12,0"
                          IsEnabled="False" SelectionChanged="OnCanvasFontSelectionChanged"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="pt" Style="{StaticResource CardTitle}" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button x:Name="FontSmallerButton" Content="−" Style="{StaticResource EditorToolbarButton}"
                            Margin="0,0,4,0" Click="OnFontSmallerClick"/>
                    <TextBox x:Name="SelectedFontSizeBox" Style="{StaticResource EditorToolbarInput}"
                             Margin="0,0,4,0" Text="—" TextAlignment="Center"
                             LostFocus="OnFontSizeBoxLostFocus" KeyDown="OnFontSizeBoxKeyDown"
                             PreviewKeyDown="OnFontSizeBoxPreviewKeyDown" IsEnabled="False"/>
                    <Button x:Name="FontLargerButton" Content="+" Style="{StaticResource EditorToolbarButton}"
                            Click="OnFontLargerClick"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#F7FAFC" CornerRadius="18" Padding="8" ClipToBounds="True"
                Height="340" MinHeight="340" MaxHeight="340">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          Background="Transparent">
                <Canvas x:Name="LayoutCanvas" Background="Transparent"/>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="DM и текст можно перетаскивать. Блок Г/В — направление текста → ← ↓ ↑. Позиция сохраняется, текст может заходить на DM."
                   Style="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap"/>
    </Grid>
</UserControl>
