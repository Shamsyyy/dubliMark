<Window x:Class="DoubleMark.Desktop.PrintTemplatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ui="clr-namespace:DoubleMark.Desktop"
        Title="Шаблоны печати"
        Height="700"
        Width="1000"
        MinHeight="620"
        MinWidth="900"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource DialogWindowFrame}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource DialogTitleBar}"
                    ui:DialogWindowChrome.IsDragArea="True">
                <Grid>
                    <TextBlock Text="Шаблоны печати" Style="{StaticResource DialogTitleText}"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource TitleBarButton}" Content="—" ui:DialogWindowChrome.WindowCommand="Minimize"/>
                        <Button Style="{StaticResource TitleBarButton}" Content="□" ui:DialogWindowChrome.WindowCommand="MaximizeRestore"/>
                        <Button Style="{StaticResource TitleBarCloseButton}" Content="×" ui:DialogWindowChrome.WindowCommand="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource HeroCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Шаблоны печати" Style="{StaticResource CardTitle}" FontSize="21"/>
                        <TextBlock Text="Выбранная строка становится активным шаблоном после сохранения."
                                   Style="{StaticResource MutedText}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Список шаблонов" Style="{StaticResource CardTitle}" Margin="0,0,0,14"/>
                            <ListBox x:Name="TemplateList"
                                     Grid.Row="1"
                                     SelectionChanged="OnTemplateSelectionChanged"
                                     Background="{StaticResource PanelAltBrush}"
                                     BorderBrush="{StaticResource BorderBrushSoft}"/>
                            <WrapPanel Grid.Row="2" Margin="0,14,0,0">
                                <Button Content="Создать"
                                        Click="OnCreateClick"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Копировать"
                                        Click="OnCopyClick"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Удалить"
                                        Click="OnDeleteClick"
                                        Style="{StaticResource DangerButton}"
                                        Margin="0,0,0,8"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Параметры шаблона" Style="{StaticResource CardTitle}" Margin="0,0,0,14"/>
                                    <TextBlock Text="Название" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="NameText" Margin="0,0,0,14"/>

                                    <TextBlock Text="Пресеты DataMatrix" Style="{StaticResource MutedText}" Margin="0,0,0,8"/>
                                    <WrapPanel Margin="0,0,0,14">
                                        <Button Content="8×8" Tag="8:8" Click="OnDmPresetClick" Style="{StaticResource SecondaryButton}" Padding="8,5" Margin="0,0,6,6"/>
                                        <Button Content="10×10" Tag="10:10" Click="OnDmPresetClick" Style="{StaticResource SecondaryButton}" Padding="8,5" Margin="0,0,6,6"/>
                                        <Button Content="13×13" Tag="13:13" Click="OnDmPresetClick" Style="{StaticResource SecondaryButton}" Padding="8,5" Margin="0,0,6,6"/>
                                        <Button Content="15×15" Tag="15:15" Click="OnDmPresetClick" Style="{StaticResource SecondaryButton}" Padding="8,5" Margin="0,0,6,6"/>
                                        <Button Content="20×30" Tag="20:30" Click="OnDmPresetClick" Style="{StaticResource SecondaryButton}" Padding="8,5" Margin="0,0,6,6"/>
                                        <Button Content="25×25" Tag="25:25" Click="OnDmPresetClick" Style="{StaticResource SecondaryButton}" Padding="8,5" Margin="0,0,0,6"/>
                                    </WrapPanel>

                                    <UniformGrid Columns="2" Margin="0,0,0,4">
                                        <StackPanel Margin="0,0,10,12">
                                            <TextBlock Text="Ширина этикетки, мм" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="LabelWidthText"/>
                                        </StackPanel>
                                        <StackPanel Margin="10,0,0,12">
                                            <TextBlock Text="Высота этикетки, мм" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="LabelHeightText"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,10,12">
                                            <TextBlock Text="DataMatrix ширина, мм" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="DmWidthText"/>
                                        </StackPanel>
                                        <StackPanel Margin="10,0,0,12">
                                            <TextBlock Text="DataMatrix высота, мм" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="DmHeightText"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,10,12">
                                            <TextBlock Text="DataMatrix X, мм" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="DmXText"/>
                                        </StackPanel>
                                        <StackPanel Margin="10,0,0,12">
                                            <TextBlock Text="DataMatrix Y, мм" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="DmYText"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,10,12">
                                            <TextBlock Text="Отступы, мм" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="MarginText"/>
                                        </StackPanel>
                                        <StackPanel Margin="10,0,0,12">
                                            <TextBlock Text="Копий по умолчанию" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="CopiesText"/>
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock Text="Поворот" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="RotationCombo"
                                              Style="{StaticResource DashboardComboBox}"
                                              Margin="0,0,0,14">
                                        <ComboBoxItem Content="0"/>
                                        <ComboBoxItem Content="90"/>
                                        <ComboBoxItem Content="180"/>
                                        <ComboBoxItem Content="270"/>
                                    </ComboBox>

                                    <TextBlock Text="Текстовые блоки: text|x|y|font|bold" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TextBlocksText"
                                             AcceptsReturn="True"
                                             Height="132"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="380"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="Предпросмотр" Style="{StaticResource CardTitle}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Белая область показывает физическую этикетку. Данные шаблона сохраняются локально."
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="StatusText"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="19"
                                                   Margin="0,14,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Width="360"
                                            Height="220"
                                            HorizontalAlignment="Right"
                                            Background="White"
                                            BorderBrush="#D6DEE8"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="8">
                                        <Canvas x:Name="PreviewCanvas" Background="White"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Применить к шаблону"
                            Click="OnApplyClick"
                            Style="{StaticResource TealButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="Сохранить"
                            Click="OnSaveClick"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="120"
                            Margin="0,0,8,0"/>
                    <Button Content="Отмена"
                            Click="OnCancelClick"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="110"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
