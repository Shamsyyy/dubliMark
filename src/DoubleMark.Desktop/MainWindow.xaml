<Window x:Class="DoubleMark.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="DoubleMark" Icon="Assets/Branding/doublemark-logo.ico" Height="860" Width="1440"
        MinHeight="760" MinWidth="1280"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        Closing="OnWindowClosing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid x:Name="RootShell" PreviewMouseDown="OnRootShellPreviewMouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#0A1016"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,10,0"/>
                    <TextBlock Text="DoubleMark" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text=" · локальная работа с Честным знаком" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="6,1,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource TitleBarButton}" Click="OnMinimizeClick" Content="—"/>
                    <Button x:Name="MaximizeRestoreButton" Style="{StaticResource TitleBarButton}" Click="OnMaximizeRestoreClick" Content="□"/>
                    <Button Style="{StaticResource TitleBarCloseButton}" Click="OnCloseClick" Content="×"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0">
            <Grid Margin="16,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Border Width="34" Height="34" CornerRadius="10"
                            Background="Transparent">
                        <Image Source="Assets/Branding/doublemark-logo.png"
                               Width="34"
                               Height="34"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"/>
                    </Border>
                    <TextBlock Text="DoubleMark" Foreground="{StaticResource TextBrush}"
                               FontSize="20" FontWeight="SemiBold" Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button x:Name="NavDashboardButton" Style="{StaticResource SidebarButtonActive}" Margin="0,0,0,10" Click="OnNavigateDashboardClick">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Stroke="{StaticResource AccentBrush}"
                                  Data="M3,10 L10,3 L17,10 M5,9 L5,17 L15,17 L15,9 M8,17 L8,12 L12,12 L12,17"/>
                            <TextBlock Text="Главная" Margin="12,0,0,0" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavScanButton" Style="{StaticResource SidebarButton}" Margin="0,0,0,10" Click="OnNavigateScanClick">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="M4,7 L4,4 L7,4 M13,4 L16,4 L16,7 M16,13 L16,16 L13,16 M7,16 L4,16 L4,13 M8,8 L12,8 L12,12 L8,12 Z"/>
                            <TextBlock Text="Сканирование" Margin="12,0,0,0" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavPrintButton" Style="{StaticResource SidebarButton}" Margin="0,0,0,10" Click="OnNavigatePrintClick">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="M5,8 L5,3 L15,3 L15,8 M5,14 L3,14 L3,8 L17,8 L17,14 L15,14 M6,12 L14,12 L14,18 L6,18 Z"/>
                            <TextBlock Text="Печать" Margin="12,0,0,0" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavTemplatesButton" Style="{StaticResource SidebarButton}" Margin="0,0,0,10" Click="OnNavigateTemplatesClick">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="M4,4 L16,4 L16,16 L4,16 Z M7,7 L9,7 M11,7 L13,7 M7,10 L9,10 M11,10 L13,10 M7,13 L9,13 M11,13 L13,13"/>
                            <TextBlock Text="Шаблоны" Margin="12,0,0,0" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavHistoryButton" Style="{StaticResource SidebarButton}" Margin="0,0,0,10" Click="OnNavigateHistoryClick">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="M10,3 A7,7 0 1 0 10,17 A7,7 0 1 0 10,3 M10,6 L10,10 L13,12"/>
                            <TextBlock Text="История" Margin="12,0,0,0" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavExportButton" Style="{StaticResource SidebarButton}" Margin="0,0,0,10" Click="OnNavigateExportClick">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="M4,7 L4,4 L7,4 M13,4 L16,4 L16,7 M16,13 L16,16 L13,16 M7,16 L4,16 L4,13 M10,6 L10,14 M6,10 L14,10"/>
                            <TextBlock Text="Экспорт" Margin="12,0,0,0" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavDiagnosticsButton" Style="{StaticResource SidebarButton}" Margin="0,0,0,10" Click="OnNavigateDiagnosticsClick">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="M3,10 C5,3 8,8 10,4 C12,8 15,3 17,10 C15,16 12,14 10,17 C8,14 5,16 3,10"/>
                            <TextBlock Text="Диагностика" Margin="12,0,0,0" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavAccountButton" Style="{StaticResource SidebarButton}" Margin="0,0,0,10" Click="OnNavigateAccountClick">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="M10,10 A3.5,3.5 0 1 0 10,3 A3.5,3.5 0 1 0 10,10 M4,17 C4.8,13.8 7,12.5 10,12.5 C13,12.5 15.2,13.8 16,17"/>
                            <TextBlock Text="ЛК" Margin="12,0,0,0" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="3" Style="{StaticResource SoftSurface}" Padding="12" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                        <Border Width="34" Height="34" CornerRadius="17" Background="Transparent">
                            <Image Source="Assets/Branding/doublemark-logo.png"
                                   Width="30"
                                   Height="30"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock x:Name="SidebarVersionText" Text="DoubleMark" Style="{StaticResource MutedText}" FontSize="12"/>
                            <TextBlock Text="© 2026" Style="{StaticResource MutedText}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="96"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="28,14,28,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="PageTitleText" Text="Главная панель" Style="{StaticResource SectionTitle}" Margin="0,0,0,4"/>
                    <Button x:Name="WorkspaceButton" Style="{StaticResource SidebarButton}" Padding="0" HorizontalAlignment="Left"
                            Background="Transparent" Click="OnWorkspaceClick">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="WorkspaceStatusDot" Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Рабочее пространство:" Margin="10,0,4,0" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                            <TextBlock x:Name="WorkspaceNameText" Text="Основное" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" FontSize="12"/>
                            <Path Width="9" Height="6" Stretch="Uniform" Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1.5"
                                  Margin="8,1,0,0" Data="M1,1 L4.5,4.5 L8,1"/>
                        </StackPanel>
                    </Button>
                    <Popup x:Name="WorkspacePopup" PlacementTarget="{Binding ElementName=WorkspaceButton}" Placement="Bottom"
                           AllowsTransparency="True" PopupAnimation="Fade" StaysOpen="False">
                        <Border Style="{StaticResource SoftSurface}" Width="230" Padding="8" Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <Button Style="{StaticResource SidebarButton}" Content="Основное" Click="OnWorkspaceOptionClick"/>
                                <Button Style="{StaticResource SidebarButton}" Content="Производство" Click="OnWorkspaceOptionClick"/>
                                <Button Style="{StaticResource SidebarButton}" Content="Тестовый стенд" Click="OnWorkspaceOptionClick"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <Grid Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                    <Border x:Name="GlobalSearchFrame" Height="44" CornerRadius="12"
                            Background="{StaticResource SoftPanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1"
                            Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="17" Height="17" Stretch="Uniform" Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1.7"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M8,3 A5,5 0 1 0 8,13 A5,5 0 1 0 8,3 M12,12 L16,16"/>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="GlobalSearchBox" Style="{StaticResource InputBox}" BorderThickness="0" Background="Transparent"
                                         TextChanged="OnGlobalSearchTextChanged" GotKeyboardFocus="OnGlobalSearchFocused"
                                         KeyDown="OnGlobalSearchKeyDown" Padding="0" VerticalContentAlignment="Center"/>
                                <TextBlock x:Name="SearchPlaceholderText" Text="Поиск по сканам, GS, серийному номеру...   Ctrl+K"
                                           Foreground="{StaticResource MutedTextBrush}" IsHitTestVisible="False"
                                           VerticalAlignment="Center" Margin="0,0,0,0" FontSize="13"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <Popup x:Name="SearchPopup" PlacementTarget="{Binding ElementName=GlobalSearchFrame}" Placement="Bottom"
                           AllowsTransparency="True" PopupAnimation="Fade" StaysOpen="True">
                        <Border Style="{StaticResource SoftSurface}" Width="{Binding ActualWidth, ElementName=GlobalSearchFrame}" MaxHeight="360" Padding="12" Effect="{StaticResource CardShadow}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Результаты поиска" Style="{StaticResource MutedText}" Margin="0,0,0,10"/>
                                    <StackPanel x:Name="SearchResultsPanel"/>
                                    <TextBlock x:Name="SearchEmptyText" Text="Ничего не найдено" Style="{StaticResource MutedText}" Visibility="Collapsed"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>

                <Grid Grid.Column="2" VerticalAlignment="Center">
                    <Button x:Name="NotificationsButton" Style="{StaticResource TitleBarButton}" Width="42" Height="42"
                            Click="OnNotificationsClick">
                        <Path Width="19" Height="19" Stretch="Uniform" Stroke="{StaticResource TextBrush}" StrokeThickness="1.6"
                              Data="M10,17 C11.1,17 12,16.2 12.2,15.2 M5,12 L5,8 C5,5.5 7,3.5 10,3.5 C13,3.5 15,5.5 15,8 L15,12 L17,14 L3,14 Z"/>
                    </Button>
                    <Border x:Name="NotificationsBadge" Width="17" Height="17" CornerRadius="8.5" Background="{StaticResource AccentBrush}"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,7,0" Visibility="Collapsed">
                        <TextBlock x:Name="NotificationsBadgeText" Text="0" FontSize="10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Popup x:Name="NotificationsPopup" PlacementTarget="{Binding ElementName=NotificationsButton}" Placement="Bottom"
                           AllowsTransparency="True" PopupAnimation="Fade" StaysOpen="False">
                        <Border Style="{StaticResource SoftSurface}" Width="340" Padding="12" Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <TextBlock Text="Уведомления" Style="{StaticResource CardTitle}" Margin="0,0,0,10"/>
                                <StackPanel x:Name="NotificationsItemsPanel"/>
                                <TextBlock x:Name="NotificationsEmptyText" Text="Событий пока нет" Style="{StaticResource MutedText}" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <Grid Grid.Column="3" VerticalAlignment="Center">
                    <Button x:Name="AccountMenuButton" Style="{StaticResource SidebarButton}" Height="54" Padding="12,0"
                            Click="OnAccountMenuClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="38" Height="38" CornerRadius="19" Background="#E7D6C5" VerticalAlignment="Center">
                                <TextBlock x:Name="AccountInitialsText" Text="DM" Foreground="#1A2028" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                                <TextBlock x:Name="AccountNameText" Text="Аккаунт DoubleMark" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="AccountOrgText" Text="Войдите в аккаунт" Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Path Grid.Column="2" Width="10" Height="7" Stretch="Uniform" Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1.6"
                                  VerticalAlignment="Center" Data="M1,1 L5,5 L9,1"/>
                        </Grid>
                    </Button>
                    <Popup x:Name="AccountPopup" PlacementTarget="{Binding ElementName=AccountMenuButton}" Placement="Bottom"
                           AllowsTransparency="True" PopupAnimation="Fade" StaysOpen="False">
                        <Border Style="{StaticResource SoftSurface}" Width="260" Padding="10" Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <TextBlock x:Name="AccountPopupNameText" Text="Аккаунт DoubleMark" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="AccountPopupEmailText" Text="Войдите в аккаунт" Style="{StaticResource MutedText}" Margin="0,2,0,10"/>
                                <Button Style="{StaticResource SidebarButton}" Content="Личный кабинет DoubleMark" Click="OnAccountProfileClick"/>
                                <Button Style="{StaticResource SidebarButton}" Content="Настройки аккаунта" Click="OnAccountProfileClick"/>
                                <Button x:Name="AccountPlanButton" Style="{StaticResource SidebarButton}" Content="Подписка DoubleMark" Click="OnAccountProfileClick"/>
                                <Button Style="{StaticResource DangerButton}" Content="Выйти" Click="OnAccountSignOutClick" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>

            <ContentControl x:Name="PageHost" Grid.Row="1" Opacity="1">
                <ContentControl.RenderTransform>
                    <TranslateTransform x:Name="PageHostTranslate" Y="0"/>
                </ContentControl.RenderTransform>
                <ContentControl.Content>
            <ScrollViewer x:Name="DashboardScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="24,0,24,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.65*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,16">
                                <Path DockPanel.Dock="Left" Width="22" Height="22" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.8"
                                      Data="M4,7 L4,4 L7,4 M13,4 L16,4 L16,7 M16,13 L16,16 L13,16 M7,16 L4,16 L4,13 M8,8 L12,8 L12,12 L8,12 Z"/>
                                <TextBlock Text="Настройки сканера" Style="{StaticResource CardTitle}" Margin="12,0,0,0"/>
                            </DockPanel>

                            <Border Style="{StaticResource SoftSurface}" Padding="12" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="ScannerStatusDot" Width="9" Height="9" Fill="{StaticResource DangerBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Сканер:" Style="{StaticResource MetricLabel}" Margin="10,0,4,0"/>
                                <TextBlock x:Name="StatusText" Text="не подключен" Foreground="{StaticResource DangerBrush}"
                                           FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            </Border>

                            <StackPanel x:Name="ComConnectionPanel">
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Режим:" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="ScannerModeCombo" Grid.Column="1" Style="{StaticResource DashboardComboBox}"
                                              SelectedIndex="0" SelectionChanged="OnDashboardScannerModeChanged">
                                        <ComboBoxItem Content="Авто"/>
                                        <ComboBoxItem Content="COM"/>
                                        <ComboBoxItem Content="HID"/>
                                    </ComboBox>
                                    <TextBlock Grid.Column="3" Text="Порт:" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="PortsCombo" Grid.Column="4" Style="{StaticResource DashboardComboBox}"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Скорость:" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="BaudRateCombo" Grid.Column="1" Style="{StaticResource DashboardComboBox}"
                                              SelectionChanged="OnBaudRateChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="108"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="108"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Click="OnConnectClick">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="16" Height="16" Stretch="Uniform" Stroke="White" StrokeThickness="1.7"
                                                  Data="M8,2 L8,7 M5,7 L11,7 M6,7 L6,11 C6,13 10,13 10,11 L10,7 M8,13 L8,16"/>
                                            <TextBlock Text="Подключить" Margin="9,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Click="OnRefreshClick" Content="Обновить"/>
                                    <Button Grid.Column="4" Style="{StaticResource SecondaryButton}" Click="OnDisconnectClick" Content="Отключить"/>
                                </Grid>
                            </StackPanel>

                            <UniformGrid Columns="2" Margin="0,2,0,12">
                                <Button Style="{StaticResource SecondaryButton}" Click="OnSetupScannerClick" Margin="0,0,6,6" Padding="10,9" Content="Настройки"/>
                                <Button Style="{StaticResource SecondaryButton}" Click="OnHidDiagnosticsClick" Margin="6,0,0,6" Padding="10,9" Content="HID diag"/>
                                <Button Style="{StaticResource SecondaryButton}" Click="OnLoadImageClick" Margin="0,6,6,0" Padding="10,9" Content="Изображение"/>
                                <Button Style="{StaticResource SecondaryButton}" Click="OnPasteImageClick" Margin="6,6,0,0" Padding="10,9" Content="Буфер"/>
                            </UniformGrid>
                            <TextBlock x:Name="PortsHintText" Style="{StaticResource MutedText}" Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" Visibility="Collapsed"/>
                            <TextBlock x:Name="WaitText" Text="Ожидание сканирования..." Style="{StaticResource MutedText}" Margin="0,8,0,0"/>
                            <Border x:Name="HidHelpPanel" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Width="23" Height="23" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.8"
                                      Data="M5,8 L5,3 L15,3 L15,8 M5,14 L3,14 L3,8 L17,8 L17,14 L15,14 M6,12 L14,12 L14,18 L6,18 Z"/>
                                <TextBlock Grid.Column="1" Text="Автопечать" Style="{StaticResource CardTitle}" Margin="12,0,8,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <TextBlock x:Name="AutoPrintStatusText" Text="Выкл." Style="{StaticResource MutedText}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="AutoPrintQuickToggle" Style="{StaticResource ToggleSwitch}"
                                              Checked="OnAutoPrintQuickToggleChanged"
                                              Unchecked="OnAutoPrintQuickToggleChanged"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Режим" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                                <ComboBox x:Name="PrintModeCombo" Grid.Column="1" Style="{StaticResource DashboardComboBox}"
                                          SelectionChanged="OnPrintModeChanged">
                                    <ComboBoxItem Content="Ручная"/>
                                    <ComboBoxItem Content="Автоматическая"/>
                                </ComboBox>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Принтер" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" CornerRadius="8" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12,9">
                                    <TextBlock x:Name="PrintPrinterText" Text="Принтер: по умолчанию" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Шаблон" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" CornerRadius="8" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12,9">
                                    <TextBlock x:Name="PrintTemplateText" Text="—" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84"/>
                                    <ColumnDefinition Width="122"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Копий" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" CornerRadius="8" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12,9">
                                    <TextBlock x:Name="PrintCopiesText" Text="1" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>

                            <Button Style="{StaticResource TealButton}" Click="OnPrintLastClick" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="17" Height="17" Stretch="Uniform" Stroke="White" StrokeThickness="1.7"
                                          Data="M5,8 L5,3 L15,3 L15,8 M5,14 L3,14 L3,8 L17,8 L17,14 L15,14 M6,12 L14,12 L14,18 L6,18 Z"/>
                                    <TextBlock Text="Печать последнего ЧЗ" Margin="9,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <UniformGrid Columns="2" Margin="0,0,0,10">
                                <Button Style="{StaticResource SecondaryButton}" Click="OnPrintSettingsClick" Margin="0,0,6,0" Content="Настройки"/>
                                <Button Style="{StaticResource SecondaryButton}" Click="OnOpenPrintFolderClick" Margin="6,0,0,0" Content="Папка печати"/>
                            </UniformGrid>
                            <TextBlock x:Name="LastPrintStatusText" Style="{StaticResource MutedText}" Foreground="#8ED6FF" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource HeroCard}" Margin="0,0,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#183E2D">
                                            <Path Width="15" Height="15" Stretch="Uniform" Stroke="{StaticResource SuccessBrush}" StrokeThickness="2"
                                                  Data="M2,7 L5.5,10.5 L12,3"/>
                                        </Border>
                                        <StackPanel Margin="12,0,0,0">
                                            <TextBlock Text="Последний скан" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock x:Name="LastScanTimeText" Text="Время скана: —" Style="{StaticResource MutedText}" Margin="0,4,0,0"/>
                                            <TextBlock Text="Живой статус распознавания и локального сохранения" Style="{StaticResource MutedText}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border x:Name="LastScanStatusBadgeBorder" Grid.Column="2" Style="{StaticResource PillBadge}"
                                            Background="#182536" BorderBrush="{StaticResource BorderBrushSoft}" VerticalAlignment="Top" MinWidth="96">
                                        <TextBlock x:Name="LastScanStatusText" Text="Ожидание" Foreground="{StaticResource MutedTextBrush}"
                                                   FontWeight="SemiBold" FontSize="13" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </Grid>

                                <UniformGrid Columns="2" Margin="0,0,0,14">
                                    <Border Style="{StaticResource DataPill}" Margin="0,0,8,8">
                                        <StackPanel>
                                            <TextBlock Text="AI 91" Style="{StaticResource MutedText}"/>
                                            <TextBlock x:Name="LastScanAi91Text" Text="—" Foreground="{StaticResource SuccessBrush}"
                                                       FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource DataPill}" Margin="8,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="AI 92 / 93" Style="{StaticResource MutedText}"/>
                                            <TextBlock x:Name="LastScanAi92Text" Text="—" Foreground="{StaticResource SuccessBrush}"
                                                       FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource DataPill}" Margin="0,8,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Серийный номер AI 21" Style="{StaticResource MutedText}"/>
                                            <TextBlock x:Name="LastScanSerialText" Text="—" Style="{StaticResource MetricValue}" FontSize="15"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource DataPill}" Margin="8,8,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="GS count" Style="{StaticResource MutedText}"/>
                                                <TextBlock x:Name="LastScanGsCountText" Text="—" Style="{StaticResource MetricValue}" FontSize="15"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Источник" Style="{StaticResource MutedText}"/>
                                                <TextBlock x:Name="LastScanSourceText" Text="—" Style="{StaticResource MetricValue}" FontSize="15"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </UniformGrid>

                                <Border Style="{StaticResource SoftSurface}" Padding="14" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Сохранено" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LastScanSavePathText" Grid.Column="1" Text="—" Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis" FontSize="13"/>
                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="OpenLastScanFolderButton" Style="{StaticResource SecondaryButton}" Click="OnOpenLastScanFolderClick" Padding="14,9" Content="Открыть папку"/>
                                    <Button Style="{StaticResource SecondaryButton}" Click="OnCopyLastScanClick" Padding="14,9" Margin="10,0,0,0" Content="Копировать данные"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="DataMatrix" Style="{StaticResource MutedText}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <Border Width="206" Height="206" CornerRadius="18" Background="#F7FAFC" Padding="15"
                                        BorderBrush="#FFFFFF" BorderThickness="1">
                                    <Grid>
                                        <Image x:Name="LastScanPreviewImage" Stretch="Uniform"/>
                                        <TextBlock x:Name="LastScanPreviewPlaceholder" Text="Нет данных" Foreground="#293241"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                                    </Grid>
                                </Border>
                                <TextBlock Text="Preview из normalized payload" Style="{StaticResource MutedText}"
                                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,16">
                                <Path DockPanel.Dock="Left" Width="22" Height="22" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.7"
                                      Data="M3,6 L8,6 L10,8 L17,8 L17,16 L3,16 Z M3,6 L3,4 L8,4 L10,6"/>
                                <TextBlock Text="Экспорт / сохранение" Style="{StaticResource CardTitle}" Margin="12,0,0,0"/>
                            </DockPanel>

                            <TextBlock Text="Папка экспорта" Style="{StaticResource MutedText}" Margin="0,0,0,8"/>
                            <Border CornerRadius="8" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12,9" Margin="0,0,0,12">
                                <TextBlock x:Name="ExportPathText" Text="—" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <CheckBox x:Name="AutoSaveCheck" Style="{StaticResource ToggleSwitch}"
                                          Checked="OnAutoSaveChanged" Unchecked="OnAutoSaveChanged"/>
                                <TextBlock Text="Автосохранение" Foreground="{StaticResource TextBrush}" Margin="10,2,0,0"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" Click="OnChooseExportFolderClick" Content="Выбрать" Padding="10,8"/>
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Click="OnOpenExportRootFolderClick" Content="Открыть" Padding="10,8"/>
                            </Grid>

                            <TextBlock x:Name="ExportStatusText" Text="Файлы сохраняются локально по дате." Style="{StaticResource MutedText}" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Path Width="22" Height="22" Stretch="Uniform" Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1.7"
                                          Data="M10,3 A7,7 0 1 0 10,17 A7,7 0 1 0 10,3 M10,6 L10,10 L13,12"/>
                                    <TextBlock Text="История" Style="{StaticResource CardTitle}" Margin="12,0,0,0"/>
                                    <TextBlock Text="(дата и время до секунды)" Style="{StaticResource MutedText}" Margin="6,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Padding="12,6"
                                        MinWidth="154" Content="Открыть всю историю"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="168"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Время" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Grid.Column="1" Text="Статус" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Grid.Column="2" Text="AI (91)" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Grid.Column="3" Text="AI (92)" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Grid.Column="4" Text="Шаблон" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Grid.Column="5" Text="Принтер" Style="{StaticResource MetricLabel}"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource BorderBrushSoft}" Margin="0,0,0,4"/>
                            <StackPanel x:Name="ResultPanel"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,16">
                                <Path DockPanel.Dock="Left" Width="22" Height="22" Stretch="Uniform" Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1.7"
                                      Data="M3,11 L6,11 L8,6 L12,16 L14,11 L17,11"/>
                                <TextBlock Text="Диагностика" Style="{StaticResource CardTitle}" Margin="12,0,0,0"/>
                            </DockPanel>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Режим" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="DiagnosticModeText" Grid.Row="0" Grid.Column="1" Text="—" Style="{StaticResource MetricValue}" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="1" Text="Сканер" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="DiagnosticScannerText" Grid.Row="1" Grid.Column="1" Text="—" Style="{StaticResource MetricValue}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Text="Статус" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="DiagnosticStatusText" Grid.Row="2" Grid.Column="1" Text="Не подключен" Style="{StaticResource MetricValue}" Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" Text="Последняя проверка" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="DiagnosticLastCheckText" Grid.Row="3" Grid.Column="1" Text="—" Style="{StaticResource MetricValue}" TextWrapping="Wrap"/>
                            </Grid>

                            <Button Style="{StaticResource SecondaryButton}" Click="OnHidDiagnosticsClick" Content="Запустить диагностику" Margin="0,0,0,12"/>
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <Button Style="{StaticResource SecondaryButton}" Click="OnOpenLogsFolderClick" Content="Открыть логи" Margin="0,0,6,0"/>
                                <Button Style="{StaticResource SecondaryButton}" Click="OnCopyDiagnosticsClick" Content="Скопировать диагностику" Margin="6,0,0,0"/>
                            </UniformGrid>
                            <Button Style="{StaticResource SecondaryButton}" Click="OnRefreshPrintersClick" Content="Обновить принтеры" Margin="0,0,0,12"/>
                            <Button Style="{StaticResource SecondaryButton}" Click="OnResetSettingsClick" Content="Сбросить настройки" Margin="0,0,0,12"/>
                            <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
                </ContentControl.Content>
            </ContentControl>
        </Grid>

        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" IsHitTestVisible="False" Panel.ZIndex="80">
            <StackPanel x:Name="ToastPanel"
                        Width="360"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,28,28"/>
        </Grid>
    </Grid>
</Window>
