<Window x:Class="DoubleMark.Desktop.ScannerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ui="clr-namespace:DoubleMark.Desktop"
        Title="Настройки сканера"
        Height="520"
        Width="640"
        MinHeight="480"
        MinWidth="580"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource DialogWindowFrame}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Настройки сканера" Style="{StaticResource CardTitle}" FontSize="21"/>
                <TextBlock Text="Авто — COM и HID одновременно. COM-порт на главной панели сохраняется отдельно."
                           Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Режим" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ModeCombo" Grid.Column="1" Style="{StaticResource DashboardComboBox}"
                                  SelectionChanged="OnModeChanged">
                            <ComboBoxItem Content="Авто"/>
                            <ComboBoxItem Content="COM"/>
                            <ComboBoxItem Content="HID"/>
                        </ComboBox>
                    </Grid>

                    <Border x:Name="ComHintPanel" Style="{StaticResource SoftSurface}" Padding="14" Margin="0,0,0,14">
                        <TextBlock x:Name="ComHintText" TextWrapping="Wrap" Foreground="{StaticResource TextBrush}"/>
                    </Border>

                    <StackPanel x:Name="HidPanel" Visibility="Collapsed">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="HID-устройства" Style="{StaticResource CardTitle}" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Обновить HID"
                                    Click="OnRefreshHidClick" Padding="12,8"/>
                        </Grid>
                        <TextBlock x:Name="HidHintText" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <CheckBox x:Name="AutoBindHidCheck" Content="Автоматически определять HID-сканер по первому быстрому скану"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" IsChecked="True"/>
                        <ComboBox x:Name="HidDevicesCombo" Style="{StaticResource DashboardComboBox}" MaxHeight="160"
                                  DisplayMemberPath="DisplayName"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Мастер: определить по скану"
                                Click="OnDetectHidClick" Margin="0,10,0,0" Padding="10,8"/>
                    </StackPanel>

                    <TextBlock x:Name="StatusText" Margin="0,16,0,0" TextWrapping="Wrap" Foreground="{StaticResource WarningBrush}"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Открыть логи" Click="OnOpenLogsClick" Style="{StaticResource SecondaryButton}"
                        MinWidth="120" Margin="0,0,8,0"/>
                <Button Content="Отмена" Click="OnCancelClick" Style="{StaticResource SecondaryButton}"
                        MinWidth="100" Margin="0,0,8,0"/>
                <Button Content="Применить" Click="OnApplyClick" Style="{StaticResource PrimaryButton}" MinWidth="110"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
