<Window x:Class="DoubleMark.Desktop.AccountSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ui="clr-namespace:DoubleMark.Desktop"
        Title="Настройки аккаунта DoubleMark"
        Height="430"
        Width="620"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource DialogWindowFrame}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource DialogTitleBar}" ui:DialogWindowChrome.IsDragArea="True">
                <Grid>
                    <TextBlock Text="Настройки аккаунта DoubleMark" Style="{StaticResource DialogTitleText}"/>
                    <Button Style="{StaticResource TitleBarCloseButton}" Content="×" HorizontalAlignment="Right"
                            ui:DialogWindowChrome.WindowCommand="Close"/>
                </Grid>
            </Border>
            <StackPanel Grid.Row="1" Margin="20">
                <TextBlock Text="Организация" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                <TextBox x:Name="OrganizationText" Style="{StaticResource InputBox}" Margin="0,0,0,14"/>
                <TextBlock Text="ИНН" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                <TextBox x:Name="InnText" Style="{StaticResource InputBox}" Margin="0,0,0,14"/>
                <TextBlock Text="Телефон" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                <TextBox x:Name="PhoneText" Style="{StaticResource InputBox}" Margin="0,0,0,14"/>
                <TextBlock Text="Email, роль, статус подписки и платежи редактируются только на сервере DoubleMark."
                           Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,18"/>
                <DockPanel LastChildFill="False">
                    <Button Content="Сменить пароль" Style="{StaticResource SecondaryButton}" Click="OnResetPasswordClick" DockPanel.Dock="Left"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Click="OnSaveClick" MinWidth="110" Margin="0,0,8,0"/>
                        <Button Content="Отмена" Style="{StaticResource SecondaryButton}" Click="OnCancelClick" MinWidth="100"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
