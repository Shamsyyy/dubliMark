<UserControl x:Class="DubliMark.Desktop.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.95*"/>
                <ColumnDefinition Width="1.05*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource HeroCard}" Margin="0,0,16,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Шаблоны печати" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Локальные шаблоны templates.json. Редактирование открывается в существующем окне управления."
                                       Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="Управление" Click="OnManageTemplatesProxyClick"/>
                    </DockPanel>
                    <StackPanel x:Name="TemplatesListPanel"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="330"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="TemplateNameText" Text="—" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Параметры выбранного шаблона" Style="{StaticResource MutedText}" Margin="0,4,0,18"/>

                        <UniformGrid Columns="2">
                            <Border Style="{StaticResource DataPill}" Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="Этикетка" Style="{StaticResource MutedText}"/>
                                    <TextBlock x:Name="TemplateLabelSizeText" Text="—" Style="{StaticResource MetricValue}" FontSize="17"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource DataPill}" Margin="8,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="DataMatrix" Style="{StaticResource MutedText}"/>
                                    <TextBlock x:Name="TemplateDmSizeText" Text="—" Style="{StaticResource MetricValue}" FontSize="17"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource DataPill}" Margin="0,8,8,0">
                                <StackPanel>
                                    <TextBlock Text="Позиция X/Y" Style="{StaticResource MutedText}"/>
                                    <TextBlock x:Name="TemplatePositionText" Text="—" Style="{StaticResource MetricValue}" FontSize="17"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource DataPill}" Margin="8,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Текстовые блоки" Style="{StaticResource MutedText}"/>
                                    <TextBlock x:Name="TemplateBlocksText" Text="—" Style="{StaticResource MetricValue}" FontSize="17"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <UniformGrid Columns="4" Margin="0,20,0,0">
                            <Button Style="{StaticResource SecondaryButton}" Content="Создать" Margin="0,0,6,0" Click="OnManageTemplatesProxyClick"/>
                            <Button Style="{StaticResource SecondaryButton}" Content="Копировать" Margin="3,0,6,0" Click="OnManageTemplatesProxyClick"/>
                            <Button Style="{StaticResource SecondaryButton}" Content="Сохранить" Margin="3,0,6,0" Click="OnManageTemplatesProxyClick"/>
                            <Button Style="{StaticResource DangerButton}" Content="Удалить" Margin="3,0,0,0" Click="OnManageTemplatesProxyClick"/>
                        </UniformGrid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Preview" Style="{StaticResource CardTitle}" Margin="0,0,0,14"/>
                        <Border Background="#F7FAFC" CornerRadius="18" Width="320" Height="230" Padding="18">
                            <Canvas x:Name="TemplatePreviewCanvas"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
