<UserControl x:Class="DubliMark.Desktop.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource HeroCard}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Шаблоны печати" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Управление локальными шаблонами этикеток." Style="{StaticResource MutedText}" Margin="0,6,0,20"/>
                    <Border Style="{StaticResource DataPill}" BorderBrush="{StaticResource AccentBrush}" Margin="0,0,0,12">
                        <TextBlock Text="ЧЗ 40×30 мм" Foreground="{StaticResource TextBrush}" FontSize="18" FontWeight="SemiBold"/>
                    </Border>
                    <Border Style="{StaticResource DataPill}" Margin="0,0,0,16">
                        <TextBlock Text="ЧЗ 30×20 мм" Foreground="{StaticResource TextBrush}" FontSize="18" FontWeight="SemiBold"/>
                    </Border>
                    <Button Style="{StaticResource PrimaryButton}" Content="Управление шаблонами" Click="OnManageTemplatesProxyClick"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Preview" Style="{StaticResource CardTitle}"/>
                    <Border Background="#F7FAFC" CornerRadius="18" Width="300" Height="220" Margin="0,18,0,0" Padding="18">
                        <Grid>
                            <Rectangle Fill="#111820" Width="120" Height="120" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="GTIN {gtin}" Foreground="#111820"/>
                                <TextBlock Text="SN {serial}" Foreground="#111820"/>
                                <TextBlock Text="{}{codeType}" Foreground="#111820" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
