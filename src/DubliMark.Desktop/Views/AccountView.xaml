<UserControl x:Class="DubliMark.Desktop.Views.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource HeroCard}" Margin="0,0,16,0">
                <StackPanel>
                    <Border Width="96" Height="96" CornerRadius="48" Background="#E7D6C5" HorizontalAlignment="Left">
                        <TextBlock Text="ИП" Foreground="#1A2028" FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Иван Петров" Foreground="{StaticResource TextBrush}" FontSize="26" FontWeight="SemiBold" Margin="0,20,0,2"/>
                    <TextBlock Text="ivan.petrov@romashka.ru" Style="{StaticResource MutedText}"/>

                    <UniformGrid Columns="2" Margin="0,24,0,0">
                        <Border Style="{StaticResource DataPill}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Тариф" Style="{StaticResource MutedText}"/>
                                <TextBlock Text="Профи" Foreground="{StaticResource SuccessBrush}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DataPill}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Статус" Style="{StaticResource MutedText}"/>
                                <TextBlock Text="Активен" Foreground="{StaticResource SuccessBrush}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,22,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Content="Настройки" Click="OnProfileSettingsClick" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource DangerButton}" Content="Выход" Click="OnSignOutClick" Margin="6,0,0,0"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Личный кабинет" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Локальный mock профиля: структура отделена, чтобы позже подключить настоящую авторизацию."
                                   Style="{StaticResource MutedText}" Margin="0,6,0,18" TextWrapping="Wrap"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Организация" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="ООО «Ромашка»" Style="{StaticResource MetricValue}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Text="Магазин" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Магазин №1" Style="{StaticResource MetricValue}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="2" Text="Рабочее пространство" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Основное" Style="{StaticResource MetricValue}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="3" Text="Авторизация" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Будет подключена позже" Style="{StaticResource MetricValue}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <UniformGrid Columns="3">
                        <Border Style="{StaticResource DataPill}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Сканы сегодня" Style="{StaticResource MutedText}"/>
                                <TextBlock Text="Локально" Style="{StaticResource MetricValue}" FontSize="18"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DataPill}" Margin="8,0">
                            <StackPanel>
                                <TextBlock Text="Экспорт" Style="{StaticResource MutedText}"/>
                                <TextBlock Text="Только ПК" Foreground="{StaticResource SuccessBrush}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DataPill}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Интеграции" Style="{StaticResource MutedText}"/>
                                <TextBlock Text="Нет" Foreground="{StaticResource WarningBrush}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
