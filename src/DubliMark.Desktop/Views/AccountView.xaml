<UserControl x:Class="DubliMark.Desktop.Views.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <Grid Margin="24,0,24,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Style="{StaticResource HeroCard}" Margin="0,0,16,0">
            <StackPanel>
                <Border Width="88" Height="88" CornerRadius="44" Background="#E7D6C5" HorizontalAlignment="Left">
                    <TextBlock Text="ИП" Foreground="#1A2028" FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Иван Петров" Foreground="{StaticResource TextBrush}" FontSize="26" FontWeight="SemiBold" Margin="0,18,0,2"/>
                <TextBlock Text="ivan.petrov@romashka.ru" Style="{StaticResource MutedText}"/>
                <Border Style="{StaticResource SoftSurface}" Margin="0,22,0,0">
                    <StackPanel>
                        <TextBlock Text="ООО «Ромашка»" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="Магазин №1 · Тариф Профи · Активен" Style="{StaticResource MutedText}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Личный кабинет" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Пока это локальный mock UI. Архитектурно страница отделена, чтобы позже подключить настоящий аккаунт."
                           Style="{StaticResource MutedText}" Margin="0,8,0,18" TextWrapping="Wrap"/>
                <Button Style="{StaticResource SecondaryButton}" Content="Настройки профиля" HorizontalAlignment="Left"/>
                <Button Style="{StaticResource DangerButton}" Content="Выход" HorizontalAlignment="Left" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
