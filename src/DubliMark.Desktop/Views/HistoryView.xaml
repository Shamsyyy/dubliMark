<UserControl x:Class="DubliMark.Desktop.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.ColumnSpan="2" Style="{StaticResource HeroCard}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="190"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="История" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Последние сканы текущей сессии, фильтры, preview и действия без повторной обработки payload."
                                   Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBox x:Name="HistorySearchBox" Grid.Column="1" Style="{StaticResource InputBox}"
                             TextChanged="OnFilterChanged"/>
                    <ComboBox x:Name="HistoryStatusFilter" Grid.Column="3" Style="{StaticResource DashboardComboBox}"
                              SelectionChanged="OnFilterChanged"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,16,0">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="154"/>
                            <ColumnDefinition Width="116"/>
                            <ColumnDefinition Width="98"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="132"/>
                            <ColumnDefinition Width="128"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Время" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Grid.Column="1" Text="Статус" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Grid.Column="2" Text="AI 91" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Grid.Column="3" Text="AI 92 / 93" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Grid.Column="4" Text="Шаблон" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Grid.Column="5" Text="Действия" Style="{StaticResource MetricLabel}"/>
                    </Grid>
                    <StackPanel x:Name="HistoryRowsPanel"/>
                    <TextBlock x:Name="HistoryEmptyText" Text="История текущей сессии пока пуста" Style="{StaticResource MutedText}"
                               Visibility="Collapsed" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="Preview" Style="{StaticResource CardTitle}"/>
                        <Border x:Name="HistoryPreviewBadge" DockPanel.Dock="Right" Style="{StaticResource PillBadge}">
                            <TextBlock x:Name="HistoryPreviewStatusText" Text="—" FontWeight="SemiBold"/>
                        </Border>
                    </DockPanel>
                    <Border Background="#F7FAFC" CornerRadius="18" Width="230" Height="230" Padding="16" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Grid>
                            <Image x:Name="HistoryPreviewImage" Stretch="Uniform"/>
                            <TextBlock x:Name="HistoryPreviewPlaceholder" Text="Выберите скан" Foreground="#293241"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="HistoryPreviewTitleText" Text="—" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="HistoryPreviewMetaText" Text="—" Style="{StaticResource MutedText}" Margin="0,6,0,12" TextWrapping="Wrap"/>
                    <Border Style="{StaticResource SoftSurface}" Margin="0,0,0,12">
                        <TextBlock x:Name="HistoryPreviewPayloadText" Text="—" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                    </Border>
                    <UniformGrid Columns="3">
                        <Button Style="{StaticResource SecondaryButton}" Content="Папка" Click="OnOpenSelectedFolderClick" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Копировать" Click="OnCopySelectedClick" Margin="3,0,6,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Печать" Click="OnReprintSelectedClick" Margin="3,0,0,0"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
