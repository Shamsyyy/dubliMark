<UserControl x:Class="DubliMark.Desktop.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*"/>
                <ColumnDefinition Width="0.98*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource HeroCard}" Margin="0,0,16,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Экспорт / сохранение" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Только локальные файлы: TXT, JSON, PNG и PDF. Никаких внешних отправок."
                                       Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock x:Name="ExportAutoText" Text="Вкл." Style="{StaticResource MutedText}" Margin="0,3,10,0"/>
                            <CheckBox x:Name="ExportAutoToggle" Style="{StaticResource ToggleSwitch}"
                                      Checked="OnAutoSaveToggleChanged" Unchecked="OnAutoSaveToggleChanged"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Text="Папка экспорта" Style="{StaticResource MetricLabel}"/>
                    <Border Style="{StaticResource SoftSurface}" Padding="14" Margin="0,0,0,14">
                        <TextBlock x:Name="ExportFolderText" Text="—" Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <UniformGrid Columns="2" Margin="0,0,0,16">
                        <Button Style="{StaticResource PrimaryButton}" Content="Выбрать папку" Click="OnChooseExportProxyClick" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Открыть папку" Click="OnOpenExportProxyClick" Margin="6,0,0,0"/>
                    </UniformGrid>

                    <Border x:Name="ExportStatusBadge" Style="{StaticResource PillBadge}" HorizontalAlignment="Left">
                        <TextBlock x:Name="ExportStatusText" Text="—" FontWeight="SemiBold"/>
                    </Border>

                    <Border Style="{StaticResource SoftSurface}" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Последнее сохранение" Style="{StaticResource MutedText}"/>
                            <TextBlock x:Name="ExportLastPathText" Text="—" Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Последние файлы" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="Показываются файлы из текущей папки экспорта и последние результаты текущей сессии."
                               Style="{StaticResource MutedText}" Margin="0,5,0,16" TextWrapping="Wrap"/>
                    <StackPanel x:Name="RecentExportFilesPanel"/>

                    <UniformGrid Columns="2" Margin="0,18,0,0">
                        <Border Style="{StaticResource DataPill}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="GS для человека" Style="{StaticResource MutedText}"/>
                                <TextBlock Text="[GS]" Foreground="{StaticResource WarningBrush}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DataPill}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="DataMatrix" Style="{StaticResource MutedText}"/>
                                <TextBlock Text="char 0x1D" Foreground="{StaticResource SuccessBrush}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
