<UserControl x:Class="DubliMark.Desktop.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource HeroCard}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Экспорт / сохранение" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Все данные сохраняются локально. Интернет-интеграции не используются."
                               Style="{StaticResource MutedText}" Margin="0,6,0,20"/>
                    <Border Style="{StaticResource SoftSurface}">
                        <TextBlock Text="%AppData%\DubliMark\exports\" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                    </Border>
                    <Button Style="{StaticResource PrimaryButton}" Content="Выбрать папку экспорта" Click="OnChooseExportProxyClick" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Локальные артефакты" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text=".txt, .json, .png, .pdf создаются только после валидного скана."
                               Style="{StaticResource MutedText}" Margin="0,8,0,16" TextWrapping="Wrap"/>
                    <Border Style="{StaticResource DataPill}" Margin="0,0,0,10">
                        <TextBlock Text="GS отображается как [GS] только для человека" Foreground="{StaticResource TextBrush}"/>
                    </Border>
                    <Border Style="{StaticResource DataPill}">
                        <TextBlock Text="DataMatrix использует настоящий char 0x1D" Foreground="{StaticResource SuccessBrush}"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
