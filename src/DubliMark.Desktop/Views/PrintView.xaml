<UserControl x:Class="DubliMark.Desktop.Views.PrintView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.04*"/>
                <ColumnDefinition Width="0.96*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource HeroCard}" Margin="0,0,16,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Печать" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Настройки берутся из текущей конфигурации. Payload не меняется: печать использует normalized с реальным GS."
                                       Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                            <TextBlock x:Name="PrintAutoStateText" Text="Выкл." Style="{StaticResource MutedText}" Margin="0,3,10,0"/>
                            <CheckBox x:Name="PrintAutoToggle" Style="{StaticResource ToggleSwitch}"
                                      Checked="OnAutoPrintToggleChanged" Unchecked="OnAutoPrintToggleChanged"/>
                        </StackPanel>
                    </DockPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Принтер" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PrinterCombo" Grid.Column="1" Style="{StaticResource DashboardComboBox}"
                                  SelectionChanged="OnPrinterSelectionChanged"/>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Шаблон" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="TemplateCombo" Grid.Column="1" Style="{StaticResource DashboardComboBox}"
                                  SelectionChanged="OnTemplateSelectionChanged"/>
                    </Grid>

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Копий" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CopiesCombo" Grid.Column="1" Style="{StaticResource DashboardComboBox}"
                                  SelectionChanged="OnCopiesSelectionChanged">
                            <ComboBoxItem Content="1"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="5"/>
                        </ComboBox>
                    </Grid>

                    <Button Style="{StaticResource TealButton}" Content="Печать последнего ЧЗ" Click="OnPrintLastProxyClick"/>
                    <UniformGrid Columns="3" Margin="0,12,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Content="Настройки" Click="OnPrintSettingsProxyClick" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Папка печати" Click="OnOpenPrintFolderProxyClick" Margin="3,0,6,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Тест" Click="OnTestPrintProxyClick" Margin="3,0,0,0"/>
                    </UniformGrid>

                    <Border Style="{StaticResource SoftSurface}" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Статус печати" Style="{StaticResource MutedText}"/>
                            <TextBlock x:Name="PrintStatusText" Text="—" Foreground="{StaticResource TextBrush}"
                                       FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="Preview этикетки" Style="{StaticResource CardTitle}"/>
                            <Border DockPanel.Dock="Right" Style="{StaticResource PillBadge}">
                                <TextBlock x:Name="PrintTemplateSizeText" Text="—" Style="{StaticResource MutedText}"/>
                            </Border>
                        </DockPanel>
                        <Border Background="#F7FAFC" CornerRadius="18" Width="320" Height="220" Padding="16" HorizontalAlignment="Center">
                            <Grid>
                                <Image x:Name="PrintPreviewImage" Stretch="Uniform"/>
                                <Grid x:Name="PrintPreviewMock">
                                    <Rectangle Fill="#111820" Width="104" Height="104" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="GTIN {gtin}" Foreground="#111820" FontWeight="SemiBold"/>
                                        <TextBlock Text="SN {serial}" Foreground="#111820"/>
                                        <TextBlock x:Name="PrintPreviewTemplateText" Text="ЧЗ" Foreground="#111820" FontWeight="Bold" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="PrintDmSizeText" Text="DataMatrix: —" Style="{StaticResource MutedText}" Margin="0,14,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <TextBlock Text="Очередь и последние печати" Style="{StaticResource CardTitle}"/>
                            <Border DockPanel.Dock="Right" Style="{StaticResource PillBadge}">
                                <TextBlock x:Name="PrintQueueText" Text="Нет активных заданий" Style="{StaticResource MutedText}"/>
                            </Border>
                        </DockPanel>
                        <TextBlock x:Name="PrintFolderText" Text="—" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <StackPanel x:Name="RecentPrintsPanel"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource DataPill}">
                        <StackPanel>
                            <TextBlock Text="Автопечать" Style="{StaticResource MutedText}"/>
                            <TextBlock x:Name="PrintAutoSummaryText" Text="—" Style="{StaticResource MetricValue}" FontSize="16"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource DataPill}">
                        <StackPanel>
                            <TextBlock Text="Принтер" Style="{StaticResource MutedText}"/>
                            <TextBlock x:Name="PrintPrinterSummaryText" Text="—" Style="{StaticResource MetricValue}" FontSize="16"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource DataPill}">
                        <StackPanel>
                            <TextBlock Text="Шаблон" Style="{StaticResource MutedText}"/>
                            <TextBlock x:Name="PrintTemplateSummaryText" Text="—" Style="{StaticResource MetricValue}" FontSize="16"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
