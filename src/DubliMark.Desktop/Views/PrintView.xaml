<UserControl x:Class="DubliMark.Desktop.Views.PrintView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource HeroCard}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Печать" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Настройки автопечати, шаблонов и локального сохранения перед печатью."
                               Style="{StaticResource MutedText}" Margin="0,6,0,20"/>
                    <TextBlock Text="Принтер" Style="{StaticResource MetricLabel}"/>
                    <ComboBox Style="{StaticResource DashboardComboBox}" Margin="0,0,0,14"/>
                    <TextBlock Text="Шаблон" Style="{StaticResource MetricLabel}"/>
                    <ComboBox Style="{StaticResource DashboardComboBox}" Margin="0,0,0,14">
                        <ComboBoxItem Content="ЧЗ 40×30 мм"/>
                        <ComboBoxItem Content="ЧЗ 30×20 мм"/>
                    </ComboBox>
                    <TextBlock Text="Копий" Style="{StaticResource MetricLabel}"/>
                    <ComboBox Style="{StaticResource DashboardComboBox}" SelectedIndex="0" Margin="0,0,0,18">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                    </ComboBox>
                    <Button Style="{StaticResource TealButton}" Content="Печать последнего ЧЗ" Click="OnPrintLastProxyClick"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Настройки печати" Click="OnPrintSettingsProxyClick" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Live preview" Style="{StaticResource CardTitle}"/>
                        <Border Background="#F7FAFC" CornerRadius="18" Width="240" Height="170" Margin="0,18,0,0" Padding="14">
                            <Grid>
                                <Rectangle Fill="#111820" Width="92" Height="92" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="ЧЗ 40×30" Foreground="#111820" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Очередь печати" Style="{StaticResource CardTitle}"/>
                        <TextBlock Text="Нет активных заданий" Style="{StaticResource MutedText}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
