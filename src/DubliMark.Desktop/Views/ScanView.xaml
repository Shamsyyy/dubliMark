<UserControl x:Class="DubliMark.Desktop.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.08*"/>
                <ColumnDefinition Width="0.92*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Style="{StaticResource HeroCard}" Margin="0,0,16,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Сканирование" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Рабочая панель COM/HID без отдельного pipeline: все действия идут в существующие handlers."
                                       Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Border x:Name="ScanStatusBadge" DockPanel.Dock="Right" Style="{StaticResource PillBadge}">
                            <TextBlock x:Name="ScanStatusText" Text="Ожидание" FontWeight="SemiBold"/>
                        </Border>
                    </DockPanel>

                    <UniformGrid Columns="3" Margin="0,0,0,18">
                        <Border Style="{StaticResource DataPill}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Источник" Style="{StaticResource MutedText}"/>
                                <TextBlock x:Name="ScanSourceText" Text="—" Style="{StaticResource MetricValue}" FontSize="16"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DataPill}" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="GS 0x1D" Style="{StaticResource MutedText}"/>
                                <TextBlock x:Name="ScanGsCountText" Text="—" Foreground="{StaticResource SuccessBrush}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DataPill}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Тип" Style="{StaticResource MutedText}"/>
                                <TextBlock x:Name="ScanCodeTypeText" Text="—" Style="{StaticResource MetricValue}" FontSize="16"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="74"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Режим" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ScanModeCombo" Grid.Column="1" Style="{StaticResource DashboardComboBox}"
                                  SelectionChanged="OnModeSelectionChanged"/>
                        <TextBlock Grid.Column="3" Text="Порт" Style="{StaticResource MetricLabel}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ScanPortsCombo" Grid.Column="4" Style="{StaticResource DashboardComboBox}"/>
                    </Grid>

                    <TextBlock x:Name="ScanPortHintText" Style="{StaticResource MutedText}" Foreground="{StaticResource WarningBrush}"
                               TextWrapping="Wrap" Visibility="Collapsed" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="128"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Click="OnConnectProxyClick" Content="Подключить COM"/>
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Click="OnRefreshPortsProxyClick" Content="Обновить"/>
                    </Grid>

                    <UniformGrid Columns="4" Margin="0,0,0,14">
                        <Button Style="{StaticResource SecondaryButton}" Click="OnSetupScannerProxyClick" Margin="0,0,6,0" Padding="10,9" Content="Настроить"/>
                        <Button Style="{StaticResource SecondaryButton}" Click="OnHidDiagnosticsProxyClick" Margin="3,0,6,0" Padding="10,9" Content="HID diag"/>
                        <Button Style="{StaticResource SecondaryButton}" Click="OnLoadImageProxyClick" Margin="3,0,6,0" Padding="10,9" Content="Изображение"/>
                        <Button Style="{StaticResource SecondaryButton}" Click="OnPasteImageProxyClick" Margin="3,0,0,0" Padding="10,9" Content="Буфер"/>
                    </UniformGrid>

                    <Border Style="{StaticResource SoftSurface}" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Последнее действие" Style="{StaticResource MutedText}"/>
                            <TextBlock x:Name="ScanWaitText" Text="Ожидание сканирования..." Foreground="{StaticResource TextBrush}"
                                       FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <TextBlock x:Name="ScanErrorText" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,14">
                        <TextBlock Text="Live preview" Style="{StaticResource CardTitle}"/>
                        <Border x:Name="ScanValidationBadge" DockPanel.Dock="Right" Style="{StaticResource PillBadge}">
                            <TextBlock x:Name="ScanValidationText" Text="Ожидание" FontWeight="SemiBold"/>
                        </Border>
                    </DockPanel>
                    <Border Background="#F7FAFC" CornerRadius="18" Width="236" Height="236" Padding="16" HorizontalAlignment="Center">
                        <Grid>
                            <Image x:Name="ScanPreviewImage" Stretch="Uniform"/>
                            <TextBlock x:Name="ScanPreviewPlaceholder" Text="Нет данных" Foreground="#293241"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                        </Grid>
                    </Border>
                    <UniformGrid Columns="2" Margin="0,18,0,0">
                        <Border Style="{StaticResource DataPill}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="GTIN / AI 01" Style="{StaticResource MutedText}"/>
                                <TextBlock x:Name="ScanGtinText" Text="—" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DataPill}" Margin="8,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Serial / AI 21" Style="{StaticResource MutedText}"/>
                                <TextBlock x:Name="ScanSerialText" Text="—" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DataPill}" Margin="0,8,8,0">
                            <StackPanel>
                                <TextBlock Text="AI 91" Style="{StaticResource MutedText}"/>
                                <TextBlock x:Name="ScanAi91Text" Text="—" Foreground="{StaticResource SuccessBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DataPill}" Margin="8,8,0,0">
                            <StackPanel>
                                <TextBlock Text="AI 92 / 93" Style="{StaticResource MutedText}"/>
                                <TextBlock x:Name="ScanAi92Text" Text="—" Foreground="{StaticResource SuccessBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <TextBlock x:Name="ScanAi93Text" Text="AI 93: —" Style="{StaticResource MutedText}" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Raw escaped" Style="{StaticResource CardTitle}"/>
                        <Border Style="{StaticResource SoftSurface}" Margin="0,12,0,0" MinHeight="118">
                            <TextBlock x:Name="ScanRawEscapedText" Text="—" Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Normalized escaped" Style="{StaticResource CardTitle}"/>
                        <Border Style="{StaticResource SoftSurface}" Margin="0,12,0,0" MinHeight="118">
                            <TextBlock x:Name="ScanNormalizedEscapedText" Text="—" Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Hex diagnostics" Style="{StaticResource CardTitle}"/>
                        <Border Style="{StaticResource SoftSurface}" Margin="0,12,0,0" MinHeight="118">
                            <TextBlock x:Name="ScanRawHexText" Text="—" Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
