<UserControl x:Class="DubliMark.Desktop.Views.DiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource HeroCard}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Диагностика" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Проверка HID, VKey/MakeCode, GS 0x1D и состояния сканера."
                               Style="{StaticResource MutedText}" Margin="0,6,0,20"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="Запустить диагностику HID" Click="OnHidDiagnosticsProxyClick"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Сбросить настройки" Click="OnResetProxyClick" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="GS health" Style="{StaticResource CardTitle}"/>
                    <Border Style="{StaticResource DataPill}" Margin="0,18,0,10">
                        <TextBlock Text="Не заменять GS на пробел, Enter, Tab или видимый символ" Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap"/>
                    </Border>
                    <Border Style="{StaticResource DataPill}">
                        <TextBlock Text="AI 92 не режется по фиксированной длине" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
