<Window x:Class="DubliMark.Desktop.ScannerSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройка сканера" Height="320" Width="520"
        Background="#1e1e1e" Foreground="White" FontFamily="Consolas"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" FontSize="14" LineHeight="22">
            Отсканируйте любой штрихкод сканером (HID).
            Приложение определит устройство по скорости ввода (&lt;50 мс между символами).
        </TextBlock>

        <Border Grid.Row="1" Background="#2d2d30" Padding="16" CornerRadius="4" Margin="0,16">
            <TextBlock x:Name="StatusText" Text="⏳ Ожидание сканирования..."
                       FontSize="16" TextWrapping="Wrap" VerticalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Click="OnCancelClick" Width="100" Margin="0,0,8,0"
                    Background="#3e3e42" Foreground="White" BorderThickness="0" Padding="10,6"/>
            <Button x:Name="DoneButton" Content="Готово" Click="OnDoneClick" Width="100"
                    IsEnabled="False" Background="#0e639c" Foreground="White"
                    BorderThickness="0" Padding="10,6"/>
        </StackPanel>
    </Grid>
</Window>
