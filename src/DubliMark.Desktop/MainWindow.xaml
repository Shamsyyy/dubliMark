<Window x:Class="DubliMark.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DubliMark — чтение ЧЗ" Height="620" Width="960"
        Background="#1e1e1e" Foreground="White" FontFamily="Consolas"
        Closing="OnWindowClosing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Connection + actions -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel x:Name="ComConnectionPanel">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="COM-порт:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="PortsCombo" Width="120" Background="#2d2d30" Foreground="White"/>
                    <Button Content="Подключить" Click="OnConnectClick" Margin="8,0,4,0"
                            Background="#0e639c" Foreground="White" BorderThickness="0" Padding="8,4"/>
                    <Button Content="Обновить" Click="OnRefreshClick"
                            Background="#3e3e42" Foreground="White" BorderThickness="0" Padding="8,4"/>
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="PortsHintText" TextWrapping="Wrap" FontSize="12" Foreground="#f0ad4e"
                           Margin="0,6,0,0" Visibility="Collapsed"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Настроить сканер" Click="OnSetupScannerClick"
                        Background="#3e3e42" Foreground="White" BorderThickness="0" Padding="8,4"/>
                <Button Content="Загрузить изображение" Click="OnLoadImageClick" Margin="8,0,0,0"
                        Background="#2d6a2d" Foreground="White" BorderThickness="0" Padding="8,4"/>
                <Button Content="Сбросить настройки" Click="OnResetSettingsClick" Margin="8,0,0,0"
                        Background="#5a1a1a" Foreground="White" BorderThickness="0" Padding="8,4"/>
                <Button Content="Диагностика HID" Click="OnHidDiagnosticsClick" Margin="8,0,0,0"
                        Background="#3e3e42" Foreground="White" BorderThickness="0" Padding="8,4"/>
                <Button Content="Из буфера" Click="OnPasteImageClick" Margin="8,0,0,0"
                        Background="#3e3e42" Foreground="White" BorderThickness="0" Padding="8,4"/>
            </StackPanel>
            <Border x:Name="HidHelpPanel" Background="#2a2a1a" BorderBrush="#5a5a30" BorderThickness="1"
                    CornerRadius="4" Padding="10" Margin="0,10,0,0">
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#ccccaa" LineHeight="18">
                    <Run FontWeight="Bold">HID и разделитель GS:</Run>
                    <LineBreak/>
                    Для чтения «Честного знака» сканер должен передавать символ GS (0x1D) между полями.
                    <LineBreak/>
                    • Netum / Symbol: включите «GS separator», «FNC1», «Transmit GS» в меню сканера.
                    <LineBreak/>
                    • Если COM-портов нет — сканер в режиме HID; для COM переключите «Virtual COM» в утилите производителя.
                    <LineBreak/>
                    • Надёжнее всего: режим Virtual COM + подключение через «Подключить».
                    <LineBreak/>
                    • Короткая матрица (~30 байт) — нормальный код без AI 91/92; полный дубль (~80+ байт) требует большую матрицу или COM.
                    • Если HID обрезает полный код после серийника — прошивка; ПО не восстанавливает AI 91/92.
                    <LineBreak/>
                    • «Диагностика HID» покажет все VKey/MakeCode и поможет настроить GS (Ctrl+], символ |, и т.д.).
                    <LineBreak/>
                    • Отладка: переменные среды DUBLIMARK_DEBUG_SCANNER=1, DUBLIMARK_LOWLEVEL_HOOK=1.
                </TextBlock>
            </Border>
        </StackPanel>

        <!-- Waiting indicator -->
        <Border Grid.Row="1" Background="#2d2d30" Padding="12" CornerRadius="4" Margin="0,0,0,12">
            <TextBlock x:Name="WaitText" Text="⏳ Ожидание сканирования..."
                       FontSize="18" HorizontalAlignment="Center" Foreground="#cccccc"/>
        </Border>

        <!-- Results -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ResultPanel"/>
        </ScrollViewer>

        <!-- Error line -->
        <TextBlock Grid.Row="3" x:Name="ErrorText" Foreground="OrangeRed"
                   TextWrapping="Wrap" Margin="0,8,0,0" FontSize="13"/>
    </Grid>
</Window>
