<Window x:Class="DubliMark.Desktop.PrintTemplatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Шаблоны печати" Height="620" Width="920"
        Background="#1e1e1e" Foreground="White" FontFamily="Consolas">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0">
            <ListBox x:Name="TemplateList" Height="420" SelectionChanged="OnTemplateSelectionChanged"
                     Background="#2d2d30" Foreground="White"/>
            <WrapPanel Margin="0,10,0,0">
                <Button Content="Создать" Click="OnCreateClick" Margin="0,0,6,6"
                        Background="#3e3e42" Foreground="White" BorderThickness="0" Padding="8,4"/>
                <Button Content="Копировать" Click="OnCopyClick" Margin="0,0,6,6"
                        Background="#3e3e42" Foreground="White" BorderThickness="0" Padding="8,4"/>
                <Button Content="Удалить" Click="OnDeleteClick" Margin="0,0,6,6"
                        Background="#5a1a1a" Foreground="White" BorderThickness="0" Padding="8,4"/>
            </WrapPanel>
        </StackPanel>

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Название"/>
                <TextBox x:Name="NameText" Margin="0,4,0,8" Background="#2d2d30" Foreground="White"/>

                <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Ширина этикетки, мм"/>
                        <TextBox x:Name="LabelWidthText" Background="#2d2d30" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Высота этикетки, мм"/>
                        <TextBox x:Name="LabelHeightText" Background="#2d2d30" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="DataMatrix ширина, мм"/>
                        <TextBox x:Name="DmWidthText" Background="#2d2d30" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="DataMatrix высота, мм"/>
                        <TextBox x:Name="DmHeightText" Background="#2d2d30" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="DataMatrix X, мм"/>
                        <TextBox x:Name="DmXText" Background="#2d2d30" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="DataMatrix Y, мм"/>
                        <TextBox x:Name="DmYText" Background="#2d2d30" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Отступы, мм"/>
                        <TextBox x:Name="MarginText" Background="#2d2d30" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Копий по умолчанию"/>
                        <TextBox x:Name="CopiesText" Background="#2d2d30" Foreground="White"/>
                    </StackPanel>
                </UniformGrid>

                <TextBlock Text="Поворот"/>
                <ComboBox x:Name="RotationCombo" Margin="0,4,0,8" Background="#2d2d30" Foreground="White">
                    <ComboBoxItem Content="0"/>
                    <ComboBoxItem Content="90"/>
                    <ComboBoxItem Content="180"/>
                    <ComboBoxItem Content="270"/>
                </ComboBox>

                <TextBlock Text="Текстовые блоки: text|x|y|font|bold"/>
                <TextBox x:Name="TextBlocksText" AcceptsReturn="True" Height="130"
                         Background="#2d2d30" Foreground="White" Margin="0,4,0,12"/>

                <Border BorderBrush="#555" BorderThickness="1" Background="White" Width="360" Height="220">
                    <Canvas x:Name="PreviewCanvas" Background="White"/>
                </Border>
                <TextBlock x:Name="StatusText" Foreground="#9cdcfe" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Применить к шаблону" Click="OnApplyClick" Background="#0e639c" Foreground="White"
                    BorderThickness="0" Padding="10,5" Margin="0,0,8,0"/>
            <Button Content="Сохранить" Click="OnSaveClick" Background="#2d6a2d" Foreground="White"
                    BorderThickness="0" Padding="10,5" Margin="0,0,8,0"/>
            <Button Content="Отмена" Click="OnCancelClick" Background="#5a1a1a" Foreground="White"
                    BorderThickness="0" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>
