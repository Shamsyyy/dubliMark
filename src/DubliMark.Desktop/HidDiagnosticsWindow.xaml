<Window x:Class="DubliMark.Desktop.HidDiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ui="clr-namespace:DubliMark.Desktop"
        Title="Диагностика HID"
        Height="680"
        Width="940"
        MinHeight="600"
        MinWidth="820"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource DialogWindowFrame}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource DialogTitleBar}"
                    ui:DialogWindowChrome.IsDragArea="True">
                <Grid>
                    <TextBlock Text="Диагностика HID" Style="{StaticResource DialogTitleText}"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource TitleBarButton}" Content="—" ui:DialogWindowChrome.WindowCommand="Minimize"/>
                        <Button Style="{StaticResource TitleBarButton}" Content="□" ui:DialogWindowChrome.WindowCommand="MaximizeRestore"/>
                        <Button Style="{StaticResource TitleBarCloseButton}" Content="×" ui:DialogWindowChrome.WindowCommand="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource HeroCard}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Диагностика HID" Style="{StaticResource CardTitle}" FontSize="21"/>
                        <TextBlock Text="Проверка событий клавиш, HEX VKey/Make и наличия GS 0x1D в потоке сканера."
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="SummaryText"
                                       Text="Ожидание сканирования..."
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="GsHintText"
                                       Margin="0,8,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource WarningBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Style="{StaticResource SoftSurface}"
                                Padding="12"
                                Margin="18,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Подсказка" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                <TextBlock Text="Если после AI 21 нет событий и в HEX нет 1D, сканер не передает GS."
                                           Foreground="{StaticResource TextBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="19"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <TabControl Grid.Row="2">
                    <TabItem Header="События клавиш">
                        <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="12">
                            <TextBox x:Name="KeysLogText"
                                     Style="{StaticResource LogTextBox}"
                                     TextWrapping="NoWrap"/>
                        </Border>
                    </TabItem>
                    <TabItem Header="HEX VKey/Make">
                        <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="12">
                            <TextBox x:Name="HexDumpText"
                                     Style="{StaticResource LogTextBox}"
                                     Foreground="{StaticResource AccentBrush}"/>
                        </Border>
                    </TabItem>
                    <TabItem Header="Буфер">
                        <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="12">
                            <TextBox x:Name="BarcodeText"
                                     Style="{StaticResource LogTextBox}"
                                     Foreground="{StaticResource WarningBrush}"/>
                        </Border>
                    </TabItem>
                </TabControl>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Копировать лог"
                            Click="OnCopyClick"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="Закрыть"
                            Click="OnCloseClick"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="110"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
